use lib.api.db.DbHandle;
use lib.api.db.db_exec;
use lib.api.db.db_query;
use lib.api.db.db_test_create_at_stem;
use lib.api.db.db_test_create_collection;
use lib.api.db.db_test_insert_json;
use lib.api.db.db_test_open_at_stem;
use lib.api.result.QueryResult;
use lib.api.result.OwnedRow;
use lib.api.result.query_result_row;
use lib.api.result.owned_row_cell_text;
use lib.api.result.owned_row_cell_u64;
use lib.api.result.owned_row_cell_i64;

const TEST_STEM_PHASE12: *const byte = "/tmp/nosqlite_phase12_features" as *const byte;

var g_phase12_db: DbHandle = DbHandle{};
var g_phase12_reopened_db: DbHandle = DbHandle{};

fn byte_slices_equal(a: &[byte], b: &[const byte]) bool {
    if a.len != b.len {
        return false;
    }
    var i: usize = 0usize;
    while i < a.len {
        if a.ptr[i] != b.ptr[i] {
            return false;
        }
        i = i + 1usize;
    }
    return true;
}

fn prepare_phase12_db(db: &DbHandle) !void {
    try db_test_create_at_stem(db, TEST_STEM_PHASE12);
    try db_test_create_collection(db, "users");
    _ = try db_test_insert_json(db, "users", "{\"name\":\"ann\",\"age\":25,\"active\":true}");
    _ = try db_test_insert_json(db, "users", "{\"name\":\"bob\",\"age\":18,\"active\":false}");
    _ = try db_test_insert_json(db, "users", "{\"name\":\"cara\",\"age\":31,\"active\":true}");
    _ = try db_test_insert_json(db, "users", "{\"name\":\"dora\",\"age\":25,\"active\":true}");
}

fn run_indexscan_order_update_delete_reopen() i32 {
    _ = prepare_phase12_db(&g_phase12_db) catch {
        return 1;
    };

    _ = db_exec(&g_phase12_db, "CREATE INDEX users_age_idx ON users ($.age);") catch {
        return 2;
    };

    const explain: QueryResult = db_query(&g_phase12_db, "EXPLAIN SELECT _id FROM users WHERE $.age = 25 LIMIT 10;") catch {
        return 3;
    };
    if explain.row_count != 1u32 || explain.column_count != 1u16 {
        return 4;
    }
    const explain_row: &OwnedRow = query_result_row(&explain, 0u32) catch {
        return 5;
    };
    const explain_text: &[byte] = owned_row_cell_text(explain_row, 0u16) catch {
        return 6;
    };
    const expected_explain: &[const byte] = "Limit 10\nIndexScan users users_age_idx $.age = 25\n";
    if !byte_slices_equal(explain_text, expected_explain) {
        return 7;
    }

    const ordered: QueryResult = db_query(&g_phase12_db, "SELECT $.name, $.age FROM users ORDER BY $.age DESC LIMIT 4;") catch {
        return 8;
    };
    if ordered.row_count != 4u32 {
        return 9;
    }
    const ordered0: &OwnedRow = query_result_row(&ordered, 0u32) catch {
        return 10;
    };
    const ordered1: &OwnedRow = query_result_row(&ordered, 1u32) catch {
        return 11;
    };
    if !byte_slices_equal((owned_row_cell_text(ordered0, 0u16) catch {
        return 12;
    }), "cara") {
        return 13;
    }
    if (owned_row_cell_i64(ordered0, 1u16) catch {
        return 14;
    }) != 31i64 {
        return 15;
    }
    if !byte_slices_equal((owned_row_cell_text(ordered1, 0u16) catch {
        return 16;
    }), "ann") {
        return 17;
    }

    _ = db_exec(&g_phase12_db, "UPDATE users SET $.age = 40 WHERE $.name = 'dora';") catch {
        return 18;
    };

    const updated_lookup: QueryResult = db_query(&g_phase12_db, "SELECT $.name, $.age FROM users WHERE $.age = 40 LIMIT 10;") catch {
        return 19;
    };
    if updated_lookup.row_count != 1u32 {
        return 20;
    }
    const updated_row: &OwnedRow = query_result_row(&updated_lookup, 0u32) catch {
        return 21;
    };
    if !byte_slices_equal((owned_row_cell_text(updated_row, 0u16) catch {
        return 22;
    }), "dora") {
        return 23;
    }
    if (owned_row_cell_i64(updated_row, 1u16) catch {
        return 24;
    }) != 40i64 {
        return 25;
    }

    _ = db_exec(&g_phase12_db, "DELETE FROM users WHERE $.active = FALSE;") catch {
        return 26;
    };

    const after_delete: QueryResult = db_query(&g_phase12_db, "SELECT _id FROM users ORDER BY _id ASC LIMIT 10;") catch {
        return 27;
    };
    if after_delete.row_count != 3u32 {
        return 28;
    }
    const row0: &OwnedRow = query_result_row(&after_delete, 0u32) catch {
        return 29;
    };
    const row1: &OwnedRow = query_result_row(&after_delete, 1u32) catch {
        return 30;
    };
    const row2: &OwnedRow = query_result_row(&after_delete, 2u32) catch {
        return 31;
    };
    if (owned_row_cell_u64(row0, 0u16) catch {
        return 32;
    }) != 1u64 {
        return 33;
    }
    if (owned_row_cell_u64(row1, 0u16) catch {
        return 34;
    }) != 3u64 {
        return 35;
    }
    if (owned_row_cell_u64(row2, 0u16) catch {
        return 36;
    }) != 4u64 {
        return 37;
    }

    _ = db_test_open_at_stem(&g_phase12_reopened_db, TEST_STEM_PHASE12) catch {
        return 38;
    };
    const reopened_by_name: QueryResult = db_query(&g_phase12_reopened_db, "SELECT $.name, $.age FROM users WHERE $.name = 'dora' LIMIT 10;") catch {
        return 48;
    };
    if reopened_by_name.row_count != 1u32 {
        return 49;
    }
    const reopened_lookup: QueryResult = db_query(&g_phase12_reopened_db, "SELECT $.name, $.age FROM users WHERE $.age = 40 LIMIT 10;") catch {
        return 39;
    };
    if reopened_lookup.row_count != 1u32 {
        return 40;
    }
    const reopened_row: &OwnedRow = query_result_row(&reopened_lookup, 0u32) catch {
        return 41;
    };
    if !byte_slices_equal((owned_row_cell_text(reopened_row, 0u16) catch {
        return 42;
    }), "dora") {
        return 43;
    }
    if (owned_row_cell_i64(reopened_row, 1u16) catch {
        return 44;
    }) != 40i64 {
        return 45;
    }

    const deleted_lookup: QueryResult = db_query(&g_phase12_reopened_db, "SELECT _id FROM users WHERE $.active = FALSE LIMIT 10;") catch {
        return 46;
    };
    if deleted_lookup.row_count != 0u32 {
        return 47;
    }
    return 0;
}

fn main() i32 {
    return run_indexscan_order_update_delete_reopen();
}
