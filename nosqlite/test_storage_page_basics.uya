use std.testing.assert_eq_bool;
use std.testing.assert_eq_i32;
use std.testing.assert_eq_u64;
use std.string.strlen;

use lib.core.types;
use lib.storage.header;
use lib.storage.meta_page;
use lib.storage.wal_header;
use lib.storage.page;
use lib.storage.slotted_page;
use lib.storage.pager;
use lib.storage.checksum;

var writer_guard_drop_releases: i32 = 0;
var page_pin_drop_releases: i32 = 0;

fn byte_slices_equal(a: &[byte], b: &[byte]) bool {
    if a.len != b.len {
        return false;
    }
    var i: usize = 0;
    while i < a.len {
        if a.ptr[i] != b.ptr[i] {
            return false;
        }
        i = i + 1;
    }
    return true;
}

fn make_meta(slot: u32, page_size: u32, min_reader_version: u32) MetaPage {
    var magic: [byte: 4] = [];
    magic[0] = 78 as byte;
    magic[1] = 83 as byte;
    magic[2] = 81 as byte;
    magic[3] = 76 as byte;
    return MetaPage{
        magic: magic,
        format_version: NOSQLITE_FORMAT_VERSION_V1,
        min_reader_version: min_reader_version,
        feature_flags: 0,
        page_size: page_size,
        generation: 1,
        commit_lsn: 0,
        checkpoint_lsn: 0,
        page_count: 2,
        catalog_root: 2,
        freelist_head: 0,
        active_meta_slot: slot,
        checksum: 0,
    };
}

fn make_wal_header(page_size: u32, min_reader_version: u32) WalHeader {
    var magic: [byte: 4] = [];
    magic[0] = 78 as byte;
    magic[1] = 83 as byte;
    magic[2] = 87 as byte;
    magic[3] = 76 as byte;
    return WalHeader{
        magic: magic,
        format_version: NOSQLITE_FORMAT_VERSION_V1,
        min_reader_version: min_reader_version,
        feature_flags: 0,
        page_size: page_size,
        header_checksum: 0,
    };
}

test "nosqlite_core_page_size_support_matrix" {
    try assert_eq_bool(page_size_is_supported(NOSQLITE_PAGE_SIZE_DEFAULT), true);
    try assert_eq_bool(page_size_is_supported(NOSQLITE_PAGE_SIZE_MAX_V1), true);
    try assert_eq_bool(page_size_is_supported(2048), false);
    try assert_eq_bool(page_size_is_supported(16384), false);
}

test "nosqlite_storage_meta_page_slot_and_support" {
    var ok_magic: MetaPage = make_meta(0, NOSQLITE_PAGE_SIZE_DEFAULT, NOSQLITE_FORMAT_VERSION_V1);
    try assert_eq_bool(meta_page_magic_valid(&ok_magic), true);
    try assert_eq_bool(meta_page_slot_valid(0), true);
    try assert_eq_bool(meta_page_slot_valid(1), true);
    try assert_eq_bool(meta_page_slot_valid(2), false);

    var ok: MetaPage = make_meta(0, NOSQLITE_PAGE_SIZE_DEFAULT, NOSQLITE_FORMAT_VERSION_V1);
    try assert_eq_bool(meta_page_supported(&ok), true);

    var bad_slot: MetaPage = make_meta(9, NOSQLITE_PAGE_SIZE_DEFAULT, NOSQLITE_FORMAT_VERSION_V1);
    try assert_eq_bool(meta_page_supported(&bad_slot), false);

    var bad_page_size: MetaPage = make_meta(0, 2048, NOSQLITE_FORMAT_VERSION_V1);
    try assert_eq_bool(meta_page_supported(&bad_page_size), false);

    var bad_reader: MetaPage = make_meta(0, NOSQLITE_PAGE_SIZE_DEFAULT, NOSQLITE_FORMAT_VERSION_V1 + 1);
    try assert_eq_bool(meta_page_supported(&bad_reader), false);

    var bad_magic: MetaPage = make_meta(0, NOSQLITE_PAGE_SIZE_DEFAULT, NOSQLITE_FORMAT_VERSION_V1);
    bad_magic.magic[0] = 88 as byte;
    try assert_eq_bool(meta_page_magic_valid(&bad_magic), false);
    try assert_eq_bool(meta_page_supported(&bad_magic), false);

    var bad_flags: MetaPage = make_meta(0, NOSQLITE_PAGE_SIZE_DEFAULT, NOSQLITE_FORMAT_VERSION_V1);
    bad_flags.feature_flags = 1;
    try assert_eq_bool(meta_page_supported(&bad_flags), false);
}

test "nosqlite_storage_wal_header_support_and_match" {
    var ok_magic: WalHeader = make_wal_header(NOSQLITE_PAGE_SIZE_DEFAULT, NOSQLITE_FORMAT_VERSION_V1);
    try assert_eq_bool(wal_header_magic_valid(&ok_magic), true);
    var ok: WalHeader = make_wal_header(NOSQLITE_PAGE_SIZE_DEFAULT, NOSQLITE_FORMAT_VERSION_V1);
    try assert_eq_bool(wal_header_supported(&ok), true);
    try assert_eq_bool(wal_header_page_size_matches(&ok, NOSQLITE_PAGE_SIZE_DEFAULT), true);
    try assert_eq_bool(wal_header_page_size_matches(&ok, NOSQLITE_PAGE_SIZE_MAX_V1), false);

    var bad_reader: WalHeader = make_wal_header(NOSQLITE_PAGE_SIZE_DEFAULT, NOSQLITE_FORMAT_VERSION_V1 + 1);
    try assert_eq_bool(wal_header_supported(&bad_reader), false);

    var bad_magic: WalHeader = make_wal_header(NOSQLITE_PAGE_SIZE_DEFAULT, NOSQLITE_FORMAT_VERSION_V1);
    bad_magic.magic[3] = 88 as byte;
    try assert_eq_bool(wal_header_magic_valid(&bad_magic), false);
    try assert_eq_bool(wal_header_supported(&bad_magic), false);

    var bad_flags: WalHeader = make_wal_header(NOSQLITE_PAGE_SIZE_DEFAULT, NOSQLITE_FORMAT_VERSION_V1);
    bad_flags.feature_flags = 1;
    try assert_eq_bool(wal_header_supported(&bad_flags), false);
}

test "nosqlite_storage_page_space_helpers" {
    var header: PageHeader = PageHeader{
        page_type: PageType.DATA,
        flags: PAGE_FLAG_NONE,
        page_lsn: 0,
        lower: 64,
        upper: 256,
        checksum: 0,
    };

    try assert_eq_i32(page_body_offset() as i32, page_header_size() as i32);
    try assert_eq_i32(page_free_space(&header) as i32, 192);
    try assert_eq_bool(page_has_room(&header, 128), true);
    try assert_eq_bool(page_has_room(&header, 193), false);

    header.lower = 300;
    header.upper = 200;
    try assert_eq_i32(page_free_space(&header) as i32, 0);
}

test "nosqlite_storage_page_header_bounds_and_slot_flags" {
    var good: PageHeader = PageHeader{
        page_type: PageType.DATA,
        flags: PAGE_FLAG_NONE,
        page_lsn: 0,
        lower: 64,
        upper: 4096,
        checksum: 0,
    };
    try assert_eq_bool(page_bounds_valid(&good, NOSQLITE_PAGE_SIZE_DEFAULT), true);

    good.lower = 0;
    try assert_eq_bool(page_bounds_valid(&good, NOSQLITE_PAGE_SIZE_DEFAULT), false);

    good.lower = 64;
    good.upper = good.lower - 1;
    try assert_eq_bool(page_bounds_valid(&good, NOSQLITE_PAGE_SIZE_DEFAULT), false);

    try assert_eq_bool(slot_is_used(SLOT_FLAG_NONE), false);
    try assert_eq_bool(slot_is_used(SLOT_FLAG_USED), true);
    try assert_eq_bool(slot_is_tombstone(SLOT_FLAG_TOMBSTONE), true);
    try assert_eq_bool(slot_is_tombstone(SLOT_FLAG_USED), false);
}

test "nosqlite_storage_page_buffer_and_checksum_helpers" {
    var raw: [byte: 256] = [];
    const page_buf: &[byte] = raw[0: 256];
    try slotted_page_init(page_buf, PageType.DATA);

    const hdr: &PageHeader = page_header_from_buf(page_buf);
    try assert_eq_bool(hdr != null, true);
    try assert_eq_bool(page_buffer_size_matches(page_buf, 256), true);
    try assert_eq_bool(page_checksum_valid(page_buf), false);

    const crc: u32 = try page_checksum_finalize(page_buf);
    try assert_eq_bool(crc != 0u32, true);
    try assert_eq_bool(page_checksum_valid(page_buf), true);

    page_buf.ptr[page_body_offset()] = 99 as byte;
    try assert_eq_bool(page_checksum_valid(page_buf), false);
}

test "nosqlite_storage_slotted_page_helpers" {
    const payload_len: usize = 48;
    const required: usize = slotted_page_required_bytes(payload_len);
    try assert_eq_i32(required as i32, (slot_size() + payload_len) as i32);
    try assert_eq_bool(record_cell_header_size() > 0, true);

    const header: PageHeader = PageHeader{
        page_type: PageType.DATA,
        flags: PAGE_FLAG_NONE,
        page_lsn: 0,
        lower: 128,
        upper: 512,
        checksum: 0,
    };

    try assert_eq_bool(slotted_page_can_fit(&header, 64), true);
    try assert_eq_bool(slotted_page_can_fit(&header, 4096), false);
}

test "nosqlite_storage_pager_policy_helpers" {
    const pressure_policy: SnapshotPressurePolicy = SnapshotPressurePolicy{
        soft_retired_bytes: 256,
        hard_retired_bytes: 1024,
        max_retired_views: 4,
        cursor_lease_ms: 30000,
    };

    const soft_status: SnapshotPressureStatus = SnapshotPressureStatus{
        retired_bytes: 300,
        retired_views: 1,
    };
    try assert_eq_bool(snapshot_pressure_soft(&pressure_policy, &soft_status), true);
    try assert_eq_bool(snapshot_pressure_hard(&pressure_policy, &soft_status), false);

    const hard_bytes: SnapshotPressureStatus = SnapshotPressureStatus{
        retired_bytes: 2048,
        retired_views: 1,
    };
    try assert_eq_bool(snapshot_pressure_hard(&pressure_policy, &hard_bytes), true);

    const hard_views: SnapshotPressureStatus = SnapshotPressureStatus{
        retired_bytes: 10,
        retired_views: 4,
    };
    try assert_eq_bool(snapshot_pressure_hard(&pressure_policy, &hard_views), true);

    const checkpoint_policy: CheckpointPolicy = CheckpointPolicy{
        wal_soft_limit_bytes: 64,
        wal_hard_limit_bytes: 256,
        wal_vs_db_ratio_milli: 250,
        max_checkpoint_interval_ms: 60000,
    };
    try assert_eq_bool(checkpoint_should_trigger_soft(&checkpoint_policy, 64), true);
    try assert_eq_bool(checkpoint_should_trigger_soft(&checkpoint_policy, 63), false);
    try assert_eq_bool(checkpoint_should_trigger_hard(&checkpoint_policy, 256), true);
    try assert_eq_bool(checkpoint_should_trigger_hard(&checkpoint_policy, 255), false);
}

test "nosqlite_storage_writer_lock_guard_helpers" {
    var guard: WriterLockGuard = writer_lock_guard_acquire(7u64, 3u64);
    try assert_eq_bool(writer_lock_guard_is_held(&guard), true);
    try assert_eq_u64(guard.owner_txn_id, 7u64);
    try assert_eq_u64(guard.lock_gen, 3u64);

    writer_lock_guard_release(&guard);
    try assert_eq_bool(writer_lock_guard_is_held(&guard), false);

    writer_lock_guard_release(&guard);
    try assert_eq_bool(writer_lock_guard_is_held(&guard), false);
}

test "nosqlite_storage_page_pin_helpers" {
    var readonly_pin: PagePin = page_pin_acquire(2u32, 11u64, 5u64, false);
    try assert_eq_bool(page_pin_is_held(&readonly_pin), true);
    try assert_eq_i32(readonly_pin.page_id as i32, 2);
    try assert_eq_u64(readonly_pin.page_lsn, 11u64);
    try assert_eq_u64(readonly_pin.view_gen, 5u64);
    try assert_eq_bool(page_pin_is_writable(&readonly_pin), false);
    try assert_eq_bool(page_pin_is_read_only(&readonly_pin), true);

    var writable_pin: PagePin = page_pin_acquire(3u32, 17u64, 9u64, true);
    try assert_eq_bool(page_pin_is_writable(&writable_pin), true);
    try assert_eq_bool(page_pin_is_read_only(&writable_pin), false);

    page_pin_release(&readonly_pin);
    try assert_eq_bool(page_pin_is_held(&readonly_pin), false);
}

test "nosqlite_storage_checksum_crc32_known_vector" {
    const data: &[byte] = &"abc"[0: 3];
    const expected: u64 = 891568578u64;
    try assert_eq_u64(checksum_bytes(data) as u64, expected);
    try assert_eq_bool(checksum_matches(data, expected as u32), true);
    try assert_eq_bool(checksum_matches(data, 0), false);
}

test "nosqlite_storage_meta_page_checksum_and_codec" {
    var page: MetaPage = make_meta(NOSQLITE_META_SLOT_A, NOSQLITE_PAGE_SIZE_DEFAULT, NOSQLITE_FORMAT_VERSION_V1);
    page.generation = 42;
    page.commit_lsn = 7;
    page.page_count = 3;
    page.catalog_root = 2;
    meta_page_finalize_checksum(&page);

    try assert_eq_i32(meta_page_encoded_size() as i32, 68);
    try assert_eq_bool(meta_page_checksum_valid(&page), true);
    try assert_eq_bool(meta_page_slot_matches_physical(&page, NOSQLITE_META_SLOT_A), true);
    try assert_eq_bool(meta_page_slot_matches_physical(&page, NOSQLITE_META_SLOT_B), false);

    var encoded: [byte: 68] = [];
    try meta_page_encode(&page, encoded[0: meta_page_encoded_size()]);
    const decoded: MetaPage = try meta_page_decode(encoded[0: meta_page_encoded_size()]);
    try assert_eq_bool(meta_page_checksum_valid(&decoded), true);
    try assert_eq_u64(decoded.generation, 42u64);
    try assert_eq_u64(decoded.commit_lsn, 7u64);
    try assert_eq_i32(decoded.page_count as i32, 3);
    try assert_eq_i32(decoded.catalog_root as i32, 2);
}

test "nosqlite_storage_wal_header_checksum_and_codec" {
    var header: WalHeader = make_wal_header(NOSQLITE_PAGE_SIZE_DEFAULT, NOSQLITE_FORMAT_VERSION_V1);
    wal_header_finalize_checksum(&header);

    try assert_eq_i32(wal_header_encoded_size() as i32, 28);
    try assert_eq_bool(wal_header_checksum_valid(&header), true);

    var encoded: [byte: 28] = [];
    try wal_header_encode(&header, encoded[0: wal_header_encoded_size()]);
    const decoded: WalHeader = try wal_header_decode(encoded[0: wal_header_encoded_size()]);
    try assert_eq_bool(wal_header_checksum_valid(&decoded), true);
    try assert_eq_i32(decoded.page_size as i32, NOSQLITE_PAGE_SIZE_DEFAULT as i32);
    try assert_eq_i32(decoded.format_version as i32, NOSQLITE_FORMAT_VERSION_V1 as i32);
}

test "nosqlite_storage_pager_meta_selection" {
    var meta_a: MetaPage = make_meta(NOSQLITE_META_SLOT_A, NOSQLITE_PAGE_SIZE_DEFAULT, NOSQLITE_FORMAT_VERSION_V1);
    meta_a.generation = 5;
    meta_a.commit_lsn = 11;
    meta_page_finalize_checksum(&meta_a);

    var meta_b: MetaPage = make_meta(NOSQLITE_META_SLOT_B, NOSQLITE_PAGE_SIZE_DEFAULT, NOSQLITE_FORMAT_VERSION_V1);
    meta_b.generation = 9;
    meta_b.commit_lsn = 10;
    meta_page_finalize_checksum(&meta_b);

    const selected_b: MetaPage = try pager_select_latest_meta(&meta_a, &meta_b);
    try assert_eq_u64(selected_b.generation, 9u64);

    meta_b.checksum = meta_b.checksum + 1;
    const selected_a: MetaPage = try pager_select_latest_meta(&meta_a, &meta_b);
    try assert_eq_u64(selected_a.generation, 5u64);

    meta_a.checksum = meta_a.checksum + 1;
    const no_meta: !MetaPage = pager_select_latest_meta(&meta_a, &meta_b);
    _ = no_meta catch {
        return;
    };
    return error.AssertionFailed;
}

test "nosqlite_storage_pager_path_and_rotation_helpers" {
    try assert_eq_i32((try pager_next_meta_slot(NOSQLITE_META_SLOT_A)) as i32, NOSQLITE_META_SLOT_B as i32);
    try assert_eq_i32((try pager_next_meta_slot(NOSQLITE_META_SLOT_B)) as i32, NOSQLITE_META_SLOT_A as i32);
    try assert_eq_u64(pager_page_offset(NOSQLITE_PAGE_SIZE_DEFAULT, 2), 8192u64);

    var db_path: [byte: 96] = [];
    var wal_path: [byte: 96] = [];
    const stem: &const byte = "/tmp/nosqlite_unit_path";
    const stem_len: usize = strlen(stem);

    try pager_build_db_path(stem, db_path[0: 96]);
    try pager_build_wal_path(stem, wal_path[0: 96]);

    try assert_eq_bool(byte_slices_equal(db_path[0: stem_len], stem[0: stem_len]), true);
    try assert_eq_i32(db_path[stem_len] as i32, 46);
    try assert_eq_i32(db_path[stem_len + 1] as i32, 110);
    try assert_eq_i32(db_path[stem_len + 2] as i32, 115);
    try assert_eq_i32(db_path[stem_len + 3] as i32, 113);
    try assert_eq_bool(byte_slices_equal(wal_path[0: stem_len], stem[0: stem_len]), true);
    try assert_eq_i32(wal_path[stem_len] as i32, 46);
    try assert_eq_i32(wal_path[stem_len + 1] as i32, 119);
    try assert_eq_i32(wal_path[stem_len + 2] as i32, 97);
    try assert_eq_i32(wal_path[stem_len + 3] as i32, 108);
}

test "nosqlite_storage_page_table_publish_and_dirty_copy" {
    var raw: [byte: 4096] = [];
    const page_buf: &[byte] = raw[0: NOSQLITE_PAGE_SIZE_DEFAULT as usize];
    try slotted_page_init(page_buf, PageType.DATA);
    _ = try slotted_page_insert_copy(page_buf, &"abc"[0: 3]);

    var frame: PageFrame = try page_frame_init_copy(2u32, 10u64, page_buf, NOSQLITE_PAGE_SIZE_DEFAULT);
    try assert_eq_i32(page_frame_capacity() as i32, NOSQLITE_PAGE_SIZE_MAX_V1 as i32);
    try assert_eq_bool(page_frame_is_private_dirty(&frame), true);
    try assert_eq_bool(page_frame_is_read_only(&frame), false);

    var table: PageTable = page_table_init(1u64);
    try page_table_insert_frame(&table, &frame);
    try assert_eq_i32(page_table_entry_count(&table) as i32, 1);
    try assert_eq_bool(page_table_is_immutable(&table), false);

    page_table_publish(&table);
    try assert_eq_bool(page_table_is_immutable(&table), true);

    var published: PageFrame = try page_table_lookup_frame(&table, 2u32);
    try assert_eq_bool(page_frame_is_read_only(&published), true);
    const original: byte = try page_frame_read_byte(&published, page_body_offset());

    const write_published: !void = page_frame_write_byte(&published, page_body_offset(), 77 as byte);
    _ = write_published catch {
        var dirty: PageFrame = try page_table_private_dirty_copy(&table, 2u32, 11u64);
        try assert_eq_bool(page_frame_is_private_dirty(&dirty), true);
        try page_frame_write_byte(&dirty, page_body_offset(), 77 as byte);
        try assert_eq_i32((try page_frame_read_byte(&dirty, page_body_offset())) as i32, 77);
        try assert_eq_i32((try page_frame_read_byte(&published, page_body_offset())) as i32, original as i32);

        const immutable_insert: !void = page_table_insert_frame(&table, &dirty);
        _ = immutable_insert catch {
            return;
        };
        return error.AssertionFailed;
    };
    return error.AssertionFailed;
}

test "nosqlite_storage_guard_drop_auto_release" {
    writer_guard_drop_releases = 0;
    page_pin_drop_releases = 0;

    {
        const guard: WriterLockGuard = writer_lock_guard_acquire_tracked(9u64, 1u64, &writer_guard_drop_releases);
        try assert_eq_bool(writer_lock_guard_is_held(&guard), true);
    }
    try assert_eq_i32(writer_guard_drop_releases, 1);

    {
        var pin: PagePin = page_pin_acquire_tracked(2u32, 3u64, 4u64, false, &page_pin_drop_releases);
        try assert_eq_bool(page_pin_is_held(&pin), true);
        page_pin_release(&pin);
    }
    try assert_eq_i32(page_pin_drop_releases, 1);

    {
        const pin2: PagePin = page_pin_acquire_tracked(2u32, 3u64, 4u64, true, &page_pin_drop_releases);
        try assert_eq_bool(page_pin_is_writable(&pin2), true);
    }
    try assert_eq_i32(page_pin_drop_releases, 2);
}

test "nosqlite_storage_cursor_lease_and_snapshot_backpressure" {
    const policy: SnapshotPressurePolicy = SnapshotPressurePolicy{
        soft_retired_bytes: 256u64,
        hard_retired_bytes: 1024u64,
        max_retired_views: 4u32,
        cursor_lease_ms: 30000u64,
    };
    const soft_status: SnapshotPressureStatus = SnapshotPressureStatus{
        retired_bytes: 300u64,
        retired_views: 1u32,
    };
    const hard_status: SnapshotPressureStatus = SnapshotPressureStatus{
        retired_bytes: 2048u64,
        retired_views: 4u32,
    };

    const lease: CursorLease = cursor_lease_start(&policy, 1000u64);
    try assert_eq_u64(lease.opened_at_ms, 1000u64);
    try assert_eq_u64(lease.deadline_ms, 31000u64);
    try assert_eq_bool(cursor_lease_is_expired(&lease, 30999u64), false);
    try assert_eq_bool(cursor_lease_is_expired(&lease, 31000u64), true);
    try assert_eq_u64(cursor_lease_remaining_ms(&lease, 2000u64), 29000u64);

    const expired: !void = cursor_lease_validate(&lease, 31000u64);
    _ = expired catch {
        try assert_eq_bool(snapshot_pressure_cursor_can_open(&policy, &soft_status), true);
        try assert_eq_bool(snapshot_pressure_cursor_can_open(&policy, &hard_status), false);
        try assert_eq_bool(snapshot_pressure_should_backpressure_writes(&policy, &soft_status), false);
        try assert_eq_bool(snapshot_pressure_should_backpressure_writes(&policy, &hard_status), true);

        const blocked: !void = snapshot_pressure_require_write_ok(&policy, &hard_status);
        _ = blocked catch {
            return;
        };
        return error.AssertionFailed;
    };
    return error.AssertionFailed;
}
