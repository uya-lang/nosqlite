use lib.api.result.owned_row_cell_i64;
use lib.api.result.owned_row_cell_bool;
use lib.api.result.owned_row_cell_text;

const TEST_STEM_EXEC: *const byte = "/tmp/nosqlite_exec_phase8" as *const byte;
const TEST_STEM_WRITE: *const byte = "/tmp/nosqlite_exec_phase10" as *const byte;

var g_exec_result_deallocs: i32 = 0;

struct CountingMallocWrapper : IAllocator {
    inner: &MallocAllocator,

    fn alloc(self: &Self, size: usize) !&byte {
        return self.inner.alloc(size);
    },

    fn dealloc(self: &Self, ptr: &byte) void {
        if ptr != null {
            g_exec_result_deallocs = g_exec_result_deallocs + 1;
        }
        self.inner.dealloc(ptr);
    },

    fn realloc(self: &Self, ptr: &byte, new_size: usize) !&byte {
        return self.inner.realloc(ptr, new_size);
    },
}

fn byte_slices_equal(a: &[byte], b: &[const byte]) bool {
    if a.len != b.len {
        return false;
    }
    var i: usize = 0usize;
    while i < a.len {
        if a.ptr[i] != b.ptr[i] {
            return false;
        }
        i = i + 1usize;
    }
    return true;
}

fn prepare_db(db: &DbHandle) !void {
    try db_test_create_at_stem(db, TEST_STEM_EXEC);
    try db_test_create_collection(db, "users");
    _ = try db_test_insert_json(db, "users", "{\"name\":\"ann\",\"age\":25,\"active\":true}");
    _ = try db_test_insert_json(db, "users", "{\"name\":\"bob\",\"age\":17,\"active\":false}");
    _ = try db_test_insert_json(db, "users", "{\"name\":\"cara\",\"age\":31,\"active\":true}");
}

fn prepare_empty_users_db(db: &DbHandle, stem: &const byte) !void {
    try db_test_create_at_stem(db, stem);
    try db_test_create_collection(db, "users");
}

fn run_cursor_seqscan_filter_limit() i32 {
    var db: DbHandle = DbHandle{};
    _ = prepare_db(&db) catch {
        return 1;
    };
    db_test_set_now_ms(&db, 1000u64);

    var cursor: QueryCursor = db_query_cursor(&db, "SELECT _id FROM users WHERE $.age >= 18 LIMIT 2;") catch {
        return 2;
    };
    if !query_cursor_is_open(&cursor) {
        return 3;
    }

    if !(cursor_next(&cursor) catch {
        return 4;
    }) {
        return 5;
    }
    const row1: RowRef = cursor_row(&cursor) catch {
        return 6;
    };
    if row1.doc_id != 1u64 {
        return 7;
    }

    if !(cursor_next(&cursor) catch {
        return 8;
    }) {
        return 9;
    }
    const row2: RowRef = cursor_row(&cursor) catch {
        return 10;
    };
    if row2.doc_id != 3u64 {
        return 11;
    }

    const third: !bool = cursor_next(&cursor);
    if third.error_id != 0u32 {
        return 12;
    }
    if third.value {
        return 13;
    }
    return 0;
}

fn run_primary_lookup_and_project() i32 {
    var db: DbHandle = DbHandle{};
    _ = prepare_db(&db) catch {
        return 21;
    };
    const result: QueryResult = db_query(&db, "SELECT _id, $.name FROM users WHERE _id = 2 LIMIT 1;") catch {
        return 22;
    };
    if result.row_count != 1u32 || result.column_count != 2u16 {
        return 23;
    }
    const row: &OwnedRow = query_result_row(&result, 0u32) catch {
        return 24;
    };
    if (owned_row_column_count(row) catch {
        return 25;
    }) != 2u16 {
        return 26;
    }
    if (owned_row_cell_u64(row, 0u16) catch {
        return 27;
    }) != 2u64 {
        return 28;
    }
    const name: &[byte] = owned_row_cell_text(row, 1u16) catch {
        return 29;
    };
    if !byte_slices_equal(name, "bob") {
        return 30;
    }
    return 0;
}

fn run_primary_lookup_uses_index() i32 {
    var db: DbHandle = DbHandle{};
    _ = prepare_db(&db) catch {
        return 31;
    };
    _ = db_test_reset_primary_index(&db, "users") catch {
        return 32;
    };
    const result: QueryResult = db_query(&db, "SELECT _id FROM users WHERE _id = 2 LIMIT 1;") catch {
        return 33;
    };
    if result.row_count != 0u32 {
        return 34;
    }
    return 0;
}

fn run_project_filter_limit_and_empty() i32 {
    var db: DbHandle = DbHandle{};
    _ = prepare_db(&db) catch {
        return 41;
    };
    const result: QueryResult = db_query(&db, "SELECT $.name, $.active FROM users WHERE NOT $.age < 18 AND $.active = TRUE LIMIT 5;") catch {
        return 42;
    };
    if result.row_count != 2u32 || result.column_count != 2u16 {
        return 43;
    }
    const row0: &OwnedRow = query_result_row(&result, 0u32) catch {
        return 44;
    };
    const row1: &OwnedRow = query_result_row(&result, 1u32) catch {
        return 45;
    };
    if !byte_slices_equal((owned_row_cell_text(row0, 0u16) catch {
        return 46;
    }), "ann") {
        return 47;
    }
    if !(owned_row_cell_bool(row0, 1u16) catch {
        return 48;
    }) {
        return 49;
    }
    if !byte_slices_equal((owned_row_cell_text(row1, 0u16) catch {
        return 50;
    }), "cara") {
        return 51;
    }

    const empty: QueryResult = db_query(&db, "SELECT _id FROM users WHERE $.age > 100 LIMIT 10;") catch {
        return 52;
    };
    if empty.row_count != 0u32 {
        return 53;
    }
    return 0;
}

fn run_error_path_cursor_expired_and_pressure() i32 {
    var db: DbHandle = DbHandle{};
    _ = prepare_db(&db) catch {
        return 61;
    };

    const bad: !QueryResult = db_query(&db, "SELECT $.missing FROM users LIMIT 1;");
    if bad.error_id == 0u32 {
        return 62;
    }

    const bad_is_null: !QueryResult = db_query(&db, "SELECT _id FROM users WHERE -$.name IS NULL LIMIT 1;");
    if bad_is_null.error_id == 0u32 {
        return 66;
    }

    db_test_set_now_ms(&db, 1000u64);
    var cursor: QueryCursor = db_query_cursor(&db, "SELECT _id FROM users LIMIT 1;") catch {
        return 63;
    };
    db_test_set_now_ms(&db, 40000u64);
    const expired: !bool = cursor_next(&cursor);
    if expired.error_id == 0u32 {
        return 64;
    }

    db_test_set_snapshot_status(&db, SnapshotPressureStatus{
        retired_bytes: 4096u64,
        retired_views: 4u32,
    });
    const pressured: SnapshotPressureStatus = db_test_snapshot_status(&db);
    if pressured.retired_bytes != 4096u64 || pressured.retired_views != 4u32 {
        return 67;
    }
    const blocked: !QueryCursor = db_query_cursor(&db, "SELECT _id FROM users LIMIT 1;");
    if blocked.error_id == 0u32 {
        return 65;
    }

    db_test_clear_snapshot_status_override(&db);
    const recovered: QueryCursor = db_query_cursor(&db, "SELECT _id FROM users LIMIT 1;") catch {
        return 68;
    };
    if !query_cursor_is_open(&recovered) {
        return 69;
    }
    return 0;
}

fn run_drop_tracking() i32 {
    var db: DbHandle = DbHandle{};
    _ = prepare_db(&db) catch {
        return 71;
    };
    var cursor_releases: i32 = 0;
    var pin_releases: i32 = 0;
    db_test_track_drops(&db, &cursor_releases, &pin_releases);

    {
        var cursor: QueryCursor = db_query_cursor(&db, "SELECT _id FROM users LIMIT 1;") catch {
            return 72;
        };
        if !query_cursor_is_open(&cursor) {
            return 73;
        }
    }

    if cursor_releases < 1 || pin_releases < 1 {
        return 74;
    }
    return 0;
}

fn run_query_result_drop_tracking() i32 {
    var db: DbHandle = DbHandle{};
    _ = prepare_db(&db) catch {
        return 81;
    };
    g_exec_result_deallocs = 0;
    var wrapper: CountingMallocWrapper = CountingMallocWrapper{ inner: get_allocator() };
    {
        const allocator: IAllocator = wrapper;
        const result: QueryResult = db_query_with_allocator(&db, "SELECT _id, $.name FROM users LIMIT 1;", allocator) catch {
            return 82;
        };
        if result.row_count != 1u32 {
            return 83;
        }
    }
    if g_exec_result_deallocs < 1 {
        return 84;
    }
    return 0;
}

fn run_commit_view_snapshot_and_retired_cleanup() i32 {
    var db: DbHandle = DbHandle{};
    _ = prepare_db(&db) catch {
        return 91;
    };
    db_test_set_now_ms(&db, 1000u64);

    const before_open: CommitView = db_test_current_commit_view(&db);
    var retired_bytes_during_pin: u64 = 0u64;

    {
        var cursor: QueryCursor = db_query_cursor(&db, "SELECT _id FROM users LIMIT 10;") catch {
            return 92;
        };
        const after_open: CommitView = db_test_current_commit_view(&db);
        const cursor_view: CommitView = query_cursor_commit_view(&cursor);
        if after_open.generation != before_open.generation || after_open.page_table_gen != before_open.page_table_gen {
            return 93;
        }
        if cursor_view.generation != before_open.generation || cursor_view.page_table_gen != before_open.page_table_gen {
            return 94;
        }

        if !(cursor_next(&cursor) catch {
            return 95;
        }) {
            return 96;
        }
        const row1: RowRef = cursor_row(&cursor) catch {
            return 97;
        };
        if row1.doc_id != 1u64 {
            return 98;
        }

        const inserted: u64 = db_test_insert_json(&db, "users", "{\"name\":\"dina\",\"age\":29,\"active\":true}") catch {
            return 99;
        };
        if inserted != 4u64 {
            return 100;
        }

        const after_commit: CommitView = db_test_current_commit_view(&db);
        if after_commit.generation <= before_open.generation || after_commit.page_table_gen <= before_open.page_table_gen {
            return 101;
        }
        if query_cursor_commit_view(&cursor).generation != before_open.generation {
            return 102;
        }

        const retired_status: SnapshotPressureStatus = db_test_snapshot_status(&db);
        retired_bytes_during_pin = retired_status.retired_bytes;
        if retired_status.retired_views != 1u32 || retired_status.retired_bytes == 0u64 {
            return 103;
        }

        if !(cursor_next(&cursor) catch {
            return 104;
        }) {
            return 105;
        }
        if (cursor_row(&cursor) catch {
            return 106;
        }).doc_id != 2u64 {
            return 107;
        }
        if !(cursor_next(&cursor) catch {
            return 108;
        }) {
            return 109;
        }
        if (cursor_row(&cursor) catch {
            return 110;
        }).doc_id != 3u64 {
            return 111;
        }
        if (cursor_next(&cursor) catch {
            return 112;
        }) {
            return 113;
        }

        const latest: QueryResult = db_query(&db, "SELECT _id FROM users LIMIT 10;") catch {
            return 114;
        };
        if latest.row_count != 4u32 {
            return 115;
        }
        if (owned_row_cell_u64((query_result_row(&latest, 3u32) catch {
            return 116;
        }), 0u16) catch {
            return 117;
        }) != 4u64 {
            return 118;
        }
    }

    const cleaned: SnapshotPressureStatus = db_test_snapshot_status(&db);
    if retired_bytes_during_pin == 0u64 {
        return 119;
    }
    if cleaned.retired_views != 0u32 || cleaned.retired_bytes != 0u64 {
        return 120;
    }
    return 0;
}

fn run_hard_snapshot_pressure_blocks_reads_and_writes() i32 {
    var db: DbHandle = DbHandle{};
    _ = prepare_db(&db) catch {
        return 121;
    };
    db_test_set_snapshot_policy(&db, SnapshotPressurePolicy{
        soft_retired_bytes: 64u64,
        hard_retired_bytes: 128u64,
        max_retired_views: 1u32,
        cursor_lease_ms: 30000u64,
    });

    {
        var cursor: QueryCursor = db_query_cursor(&db, "SELECT _id FROM users LIMIT 10;") catch {
            return 122;
        };
        _ = db_test_insert_json(&db, "users", "{\"name\":\"erin\",\"age\":22,\"active\":true}") catch {
            return 123;
        };

        const status: SnapshotPressureStatus = db_test_snapshot_status(&db);
        if status.retired_views != 1u32 || status.retired_bytes < 128u64 {
            return 124;
        }

        const blocked_cursor: !QueryCursor = db_query_cursor(&db, "SELECT _id FROM users LIMIT 1;");
        if blocked_cursor.error_id == 0u32 {
            return 125;
        }

        const blocked_write: !u64 = db_test_insert_json(&db, "users", "{\"name\":\"faye\",\"age\":24,\"active\":false}");
        if blocked_write.error_id == 0u32 {
            return 126;
        }

        if !(cursor_next(&cursor) catch {
            return 127;
        }) {
            return 128;
        }
    }

    const cleaned: SnapshotPressureStatus = db_test_snapshot_status(&db);
    if cleaned.retired_views != 0u32 || cleaned.retired_bytes != 0u64 {
        return 129;
    }

    const reopened: QueryCursor = db_query_cursor(&db, "SELECT _id FROM users LIMIT 1;") catch {
        return 130;
    };
    if !query_cursor_is_open(&reopened) {
        return 131;
    }
    return 0;
}

fn run_insert_autocommit_and_query() i32 {
    var db: DbHandle = DbHandle{};
    _ = prepare_empty_users_db(&db, TEST_STEM_WRITE) catch {
        return 141;
    };
    _ = db_exec(&db, "INSERT INTO users JSON '{\"name\":\"ann\",\"age\":25,\"active\":true}';") catch {
        return 142;
    };
    const result: QueryResult = db_query(&db, "SELECT _id, $.name, $.age FROM users WHERE _id = 1 LIMIT 1;") catch {
        return 143;
    };
    if result.row_count != 1u32 || result.column_count != 3u16 {
        return 144;
    }
    const row: &OwnedRow = query_result_row(&result, 0u32) catch {
        return 145;
    };
    if (owned_row_cell_u64(row, 0u16) catch {
        return 146;
    }) != 1u64 {
        return 147;
    }
    if !byte_slices_equal((owned_row_cell_text(row, 1u16) catch {
        return 148;
    }), "ann") {
        return 149;
    }
    if (owned_row_cell_i64(row, 2u16) catch {
        return 150;
    }) != 25i64 {
        return 151;
    }
    return 0;
}

fn run_txn_uncommitted_invisible_then_commit() i32 {
    var db: DbHandle = DbHandle{};
    _ = prepare_empty_users_db(&db, TEST_STEM_WRITE) catch {
        return 152;
    };
    var txn: Txn = txn_begin(&db) catch {
        return 153;
    };
    _ = txn_exec(&txn, "INSERT INTO users JSON '{\"name\":\"beth\",\"age\":18,\"active\":false}';") catch {
        return 154;
    };
    const before: QueryResult = db_query(&db, "SELECT _id FROM users LIMIT 10;") catch {
        return 155;
    };
    if before.row_count != 0u32 {
        return 156;
    }
    _ = txn_commit(&txn) catch {
        return 157;
    };
    const after: QueryResult = db_query(&db, "SELECT _id, $.name FROM users LIMIT 10;") catch {
        return 158;
    };
    if after.row_count != 1u32 {
        return 159;
    }
    const row: &OwnedRow = query_result_row(&after, 0u32) catch {
        return 160;
    };
    if (owned_row_cell_u64(row, 0u16) catch {
        return 161;
    }) != 1u64 {
        return 162;
    }
    if !byte_slices_equal((owned_row_cell_text(row, 1u16) catch {
        return 163;
    }), "beth") {
        return 164;
    }
    return 0;
}

fn run_txn_rollback_and_drop_abort() i32 {
    var db: DbHandle = DbHandle{};
    _ = prepare_empty_users_db(&db, TEST_STEM_WRITE) catch {
        return 165;
    };
    {
        var txn: Txn = txn_begin(&db) catch {
            return 166;
        };
        _ = txn_exec(&txn, "INSERT INTO users JSON '{\"name\":\"cara\",\"age\":31,\"active\":true}';") catch {
            return 167;
        };
        _ = txn_rollback(&txn) catch {
            return 168;
        };
    }
    const after_rollback: QueryResult = db_query(&db, "SELECT _id FROM users LIMIT 10;") catch {
        return 169;
    };
    if after_rollback.row_count != 0u32 {
        return 170;
    }

    {
        var txn2: Txn = txn_begin(&db) catch {
            return 171;
        };
        _ = txn_exec(&txn2, "INSERT INTO users JSON '{\"name\":\"dina\",\"age\":29,\"active\":true}';") catch {
            return 172;
        };
    }
    const after_drop: QueryResult = db_query(&db, "SELECT _id FROM users LIMIT 10;") catch {
        return 173;
    };
    if after_drop.row_count != 0u32 {
        return 174;
    }
    _ = db_exec(&db, "INSERT INTO users JSON '{\"name\":\"eve\",\"age\":20,\"active\":true}';") catch {
        return 175;
    };
    const after_reuse: QueryResult = db_query(&db, "SELECT _id, $.name FROM users LIMIT 10;") catch {
        return 176;
    };
    if after_reuse.row_count != 1u32 {
        return 177;
    }
    const row: &OwnedRow = query_result_row(&after_reuse, 0u32) catch {
        return 178;
    };
    if (owned_row_cell_u64(row, 0u16) catch {
        return 179;
    }) != 1u64 {
        return 180;
    }
    if !byte_slices_equal((owned_row_cell_text(row, 1u16) catch {
        return 181;
    }), "eve") {
        return 182;
    }
    return 0;
}

fn run_insert_persists_after_reopen() i32 {
    var db: DbHandle = DbHandle{};
    _ = prepare_empty_users_db(&db, TEST_STEM_WRITE) catch {
        return 175;
    };
    _ = db_exec(&db, "INSERT INTO users JSON '{\"name\":\"erin\",\"age\":22,\"active\":true}';") catch {
        return 176;
    };
    _ = db_exec(&db, "INSERT INTO users JSON '{\"name\":\"faye\",\"age\":24,\"active\":false}';") catch {
        return 177;
    };

    var reopened: DbHandle = DbHandle{};
    _ = db_test_open_at_stem(&reopened, TEST_STEM_WRITE) catch {
        return 178;
    };
    const result: QueryResult = db_query(&reopened, "SELECT _id, $.name FROM users LIMIT 10;") catch {
        return 179;
    };
    if result.row_count != 2u32 {
        return 180;
    }
    const row0: &OwnedRow = query_result_row(&result, 0u32) catch {
        return 181;
    };
    const row1: &OwnedRow = query_result_row(&result, 1u32) catch {
        return 182;
    };
    if (owned_row_cell_u64(row0, 0u16) catch {
        return 183;
    }) != 1u64 {
        return 184;
    }
    if !byte_slices_equal((owned_row_cell_text(row0, 1u16) catch {
        return 185;
    }), "erin") {
        return 186;
    }
    if (owned_row_cell_u64(row1, 0u16) catch {
        return 187;
    }) != 2u64 {
        return 188;
    }
    if !byte_slices_equal((owned_row_cell_text(row1, 1u16) catch {
        return 189;
    }), "faye") {
        return 190;
    }
    return 0;
}

fn main() i32 {
    const a: i32 = run_cursor_seqscan_filter_limit();
    if a != 0 {
        return a;
    }
    const b: i32 = run_primary_lookup_and_project();
    if b != 0 {
        return b;
    }
    const b2: i32 = run_primary_lookup_uses_index();
    if b2 != 0 {
        return b2;
    }
    const c: i32 = run_project_filter_limit_and_empty();
    if c != 0 {
        return c;
    }
    const d: i32 = run_error_path_cursor_expired_and_pressure();
    if d != 0 {
        return d;
    }
    const e: i32 = run_drop_tracking();
    if e != 0 {
        return e;
    }
    const f: i32 = run_query_result_drop_tracking();
    if f != 0 {
        return f;
    }
    const g: i32 = run_commit_view_snapshot_and_retired_cleanup();
    if g != 0 {
        return g;
    }
    const h: i32 = run_hard_snapshot_pressure_blocks_reads_and_writes();
    if h != 0 {
        return h;
    }
    const i: i32 = run_insert_autocommit_and_query();
    if i != 0 {
        return i;
    }
    const j: i32 = run_txn_uncommitted_invisible_then_commit();
    if j != 0 {
        return j;
    }
    const k: i32 = run_txn_rollback_and_drop_abort();
    if k != 0 {
        return k;
    }
    const l: i32 = run_insert_persists_after_reopen();
    if l != 0 {
        return l;
    }
    return 0;
}
