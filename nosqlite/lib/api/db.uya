export const DB_MAX_COLLECTIONS: usize = 4;
export const DB_MAX_ROWS_PER_COLLECTION: usize = 64;
export const DB_MAX_CURSOR_ROWS: usize = 64;
const DB_MAX_SECONDARY_INDEXES_PER_COLLECTION: usize = 8;
const DB_MAX_COMMIT_VIEWS: usize = 8;
const DB_PATH_BUF_SIZE: usize = 512;
const DB_DOC_BLOB_MAX: usize = 4096;
const DB_TXN_DOC_SCRATCH_MAX: usize = 8192;
const DB_JSON_VALUE_ALLOC_SIZE: usize = 64;
const DB_JSON_KEY_VALUE_ALLOC_SIZE: usize = 48;
const DB_VIEW_BASE_RETAINED_BYTES: u64 = 64u64;
const DB_COLLECTION_RETAINED_BYTES: u64 = 32u64;
const DB_ROW_RETAINED_BYTES: u64 = 16u64;

struct DbStoredRow {
    present: bool,
    tombstone: bool,
    doc_id: u64,
    record_ptr: RecordPointer,
    doc_len: u16,
    doc_blob: [byte: DB_DOC_BLOB_MAX],
}

struct DbCollectionIndexMeta {
    present: bool,
    index_id: u32,
    root_page: u32,
    path_segment_count: u16,
    name_len: u16,
    path_len: u16,
    name: [byte: 64],
    path: [byte: 128],
}

struct DbCollection {
    present: bool,
    collection_id: u32,
    name_len: u16,
    name: [byte: 64],
    next_doc_id: u64,
    primary_root_page: u32,
    secondary_index_count: u16,
    secondary_indexes: [DbCollectionIndexMeta: DB_MAX_SECONDARY_INDEXES_PER_COLLECTION],
    row_count: u16,
    rows: [DbStoredRow: DB_MAX_ROWS_PER_COLLECTION],
}

struct DbSecondaryIndexState {
    present: bool,
    index_id: u32,
    name_len: u16,
    name: [byte: 64],
    path_len: u16,
    path: [byte: 128],
    path_program: PathProgram,
    row_count: u16,
    row_slots: [u16: DB_MAX_ROWS_PER_COLLECTION],
}

export struct CommitView {
    generation: u64,
    commit_lsn: u64,
    catalog_root: u32,
    page_count: u32,
    freelist_head: u32,
    page_table_gen: u64,
}

struct CommitViewState {
    present: bool,
    retired: bool,
    reader_pins: u32,
    retained_bytes: u64,
    view: CommitView,
    collection_count: u16,
    collections: [DbCollection: DB_MAX_COLLECTIONS],
}

export struct DbHandle {
    stem_len: u16,
    stem: [byte: DB_PATH_BUF_SIZE],
    snapshot_policy: SnapshotPressurePolicy,
    snapshot_status: SnapshotPressureStatus,
    snapshot_status_override_enabled: bool,
    snapshot_status_override: SnapshotPressureStatus,
    now_ms: u64,
    current_view_slot: u16,
    next_view_generation: u64,
    next_page_table_gen: u64,
    commit_views: [CommitViewState: DB_MAX_COMMIT_VIEWS],
    primary_indexes: [PrimaryBTree: DB_MAX_COLLECTIONS],
    secondary_indexes: [DbSecondaryIndexState: DB_MAX_COLLECTIONS * DB_MAX_SECONDARY_INDEXES_PER_COLLECTION],
    cursor_release_counter: &i32,
    pin_release_counter: &i32,
}

export struct CommitViewPin {
    db: &DbHandle,
    view_slot: u16,
    view: CommitView,
    lease: CursorLease,
    held: bool,
    release_counter: &i32,

    fn drop(self: CommitViewPin) void {
        commit_view_pin_drop(self);
    },
}

export struct DocBlobBuilder {
    active: bool,
    doc_len: u16,
    scratch: [byte: DB_TXN_DOC_SCRATCH_MAX],
    doc_blob: [byte: DB_DOC_BLOB_MAX],

    fn drop(self: DocBlobBuilder) void {
        doc_blob_builder_drop(self);
    },
}

export struct Txn {
    db: &DbHandle,
    writer_guard: WriterLockGuard,
    view_slot: u16,
    has_writes: bool,
    active: bool,
    committed: bool,

    fn drop(self: Txn) void {
        txn_drop(self);
    },
}

export struct QueryCursor {
    db: &DbHandle,
    pin: CommitViewPin,
    plan: QueryPlan,
    collection_slot: u16,
    match_count: u16,
    match_rows: [u16: DB_MAX_CURSOR_ROWS],
    next_index: u16,
    has_current: bool,
    current_row: RowRef,
    release_counter: &i32,

    fn drop(self: QueryCursor) void {
        query_cursor_drop(self);
    },
}

export struct DbCheckReport {
    page_count: u32,
    checked_pages: u32,
    collection_count: u32,
    row_count: u32,
    wal_bytes: u64,
    wal_records: u32,
    committed_wal_txns: u32,
}

enum ExecValueKind {
    NULL,
    BOOL,
    INT64,
    UINT64,
    NUMBER_TEXT,
    STRING,
    DOC_NODE,
}

struct ExecValue {
    kind: ExecValueKind,
    bool_value: bool,
    i64_value: i64,
    u64_value: u64,
    text_len: u16,
    text: [byte: 2048],
    doc_node: &[byte],
}

fn db_store_u16_le(out: &[byte], off: usize, value: u16) void {
    out.ptr[off] = ((value & 255u16) as! byte).value;
    out.ptr[off + 1usize] = (((value >> 8) & 255u16) as! byte).value;
}

fn db_store_u32_le(out: &[byte], off: usize, value: u32) void {
    out.ptr[off] = ((value & 255u32) as! byte).value;
    out.ptr[off + 1usize] = (((value >> 8) & 255u32) as! byte).value;
    out.ptr[off + 2usize] = (((value >> 16) & 255u32) as! byte).value;
    out.ptr[off + 3usize] = (((value >> 24) & 255u32) as! byte).value;
}

fn db_store_u64_le(out: &[byte], off: usize, value: u64) void {
    out.ptr[off] = ((value & 255u64) as! byte).value;
    out.ptr[off + 1usize] = (((value >> 8) & 255u64) as! byte).value;
    out.ptr[off + 2usize] = (((value >> 16) & 255u64) as! byte).value;
    out.ptr[off + 3usize] = (((value >> 24) & 255u64) as! byte).value;
    out.ptr[off + 4usize] = (((value >> 32) & 255u64) as! byte).value;
    out.ptr[off + 5usize] = (((value >> 40) & 255u64) as! byte).value;
    out.ptr[off + 6usize] = (((value >> 48) & 255u64) as! byte).value;
    out.ptr[off + 7usize] = (((value >> 56) & 255u64) as! byte).value;
}

fn db_load_u16_le(data: &[byte], off: usize) u16 {
    return (data.ptr[off] as u16) |
        ((data.ptr[off + 1usize] as u16) << 8);
}

fn db_load_u32_le(data: &[byte], off: usize) u32 {
    return (data.ptr[off] as u32) |
        ((data.ptr[off + 1usize] as u32) << 8) |
        ((data.ptr[off + 2usize] as u32) << 16) |
        ((data.ptr[off + 3usize] as u32) << 24);
}

fn db_load_u64_le(data: &[byte], off: usize) u64 {
    return (data.ptr[off] as u64) |
        ((data.ptr[off + 1usize] as u64) << 8) |
        ((data.ptr[off + 2usize] as u64) << 16) |
        ((data.ptr[off + 3usize] as u64) << 24) |
        ((data.ptr[off + 4usize] as u64) << 32) |
        ((data.ptr[off + 5usize] as u64) << 40) |
        ((data.ptr[off + 6usize] as u64) << 48) |
        ((data.ptr[off + 7usize] as u64) << 56);
}

fn db_copy_name(name: &[const byte], out: &[byte], len_out: &u16) !void {
    if name.ptr == null || out.ptr == null || len_out == null || name.len > 64usize {
        return error.DbCollectionNotFound;
    }
    len_out[0] = (name.len as! u16) catch {
        return error.DbCollectionNotFound;
    };
    if name.len > 0 {
        _ = mem_copy(out.ptr, name.ptr, name.len);
    }
}

fn db_copy_path(path: &[const byte], out: &[byte], len_out: &u16) !void {
    if path.ptr == null || out.ptr == null || len_out == null || path.len > 128usize {
        return error.DbInvalidExpr;
    }
    len_out[0] = (path.len as! u16) catch {
        return error.DbInvalidExpr;
    };
    if path.len > 0 {
        _ = mem_copy(out.ptr, path.ptr, path.len);
    }
}

fn db_collection_index_reset(index_meta: &DbCollectionIndexMeta) void {
    if index_meta == null {
        return;
    }
    index_meta.present = false;
    index_meta.index_id = 0u32;
    index_meta.root_page = 0u32;
    index_meta.path_segment_count = 0u16;
    index_meta.name_len = 0u16;
    index_meta.path_len = 0u16;
}

fn db_secondary_index_state_reset(index_state: &DbSecondaryIndexState) void {
    if index_state == null {
        return;
    }
    index_state.present = false;
    index_state.index_id = 0u32;
    index_state.name_len = 0u16;
    index_state.path_len = 0u16;
    index_state.path_program = PathProgram{};
    index_state.row_count = 0u16;
}

fn db_secondary_index_flat_slot(collection_slot: u16, index_slot: u16) !usize {
    const collection_idx: usize = (collection_slot as! usize) catch {
        return error.DbCollectionNotFound;
    };
    const index_idx: usize = (index_slot as! usize) catch {
        return error.DbCollectionNotFound;
    };
    if collection_idx >= DB_MAX_COLLECTIONS || index_idx >= DB_MAX_SECONDARY_INDEXES_PER_COLLECTION {
        return error.DbCollectionNotFound;
    }
    return collection_idx * DB_MAX_SECONDARY_INDEXES_PER_COLLECTION + index_idx;
}

fn db_secondary_index_state(db: &DbHandle, collection_slot: u16, index_slot: u16) !&DbSecondaryIndexState {
    if db == null {
        return error.DbHandleInvalid;
    }
    const flat: usize = try db_secondary_index_flat_slot(collection_slot, index_slot);
    if flat >= DB_MAX_COLLECTIONS * DB_MAX_SECONDARY_INDEXES_PER_COLLECTION {
        return error.DbCollectionNotFound;
    }
    return &db.secondary_indexes[flat];
}

fn db_collection_at_in_state(state: &CommitViewState, collection_slot: u16) !&DbCollection {
    if state == null {
        return error.DbCollectionNotFound;
    }
    const idx: usize = (collection_slot as! usize) catch {
        return error.DbCollectionNotFound;
    };
    if idx >= DB_MAX_COLLECTIONS {
        return error.DbCollectionNotFound;
    }
    return &state.collections[idx];
}

fn db_row_at(collection: &DbCollection, row_slot: u16) !&DbStoredRow {
    if collection == null {
        return error.DbCollectionNotFound;
    }
    const idx: usize = (row_slot as! usize) catch {
        return error.DbCollectionNotFound;
    };
    if idx >= DB_MAX_ROWS_PER_COLLECTION {
        return error.DbCollectionNotFound;
    }
    return &collection.rows[idx];
}

fn db_index_name_equal(index_meta: &DbCollectionIndexMeta, name: &[const byte]) bool {
    if index_meta == null || !index_meta.present || name.ptr == null || index_meta.name_len as usize != name.len {
        return false;
    }
    var i: usize = 0usize;
    while i < name.len {
        if index_meta.name[i] != name.ptr[i] {
            return false;
        }
        i = i + 1usize;
    }
    return true;
}

fn db_index_path_equal(index_meta: &DbCollectionIndexMeta, path: &[const byte]) bool {
    if index_meta == null || !index_meta.present || path.ptr == null || index_meta.path_len as usize != path.len {
        return false;
    }
    var i: usize = 0usize;
    while i < path.len {
        if index_meta.path[i] != path.ptr[i] {
            return false;
        }
        i = i + 1usize;
    }
    return true;
}

fn db_stem_ptr(db: &DbHandle) &const byte {
    if db == null {
        return null;
    }
    return &db.stem[0] as &const byte;
}

fn db_collection_reset(collection: &DbCollection) void {
    if collection == null {
        return;
    }
    collection.present = false;
    collection.collection_id = 0u32;
    collection.name_len = 0u16;
    collection.next_doc_id = 0u64;
    collection.primary_root_page = 0u32;
    collection.secondary_index_count = 0u16;
    collection.row_count = 0u16;
    var index_idx: usize = 0usize;
    while index_idx < DB_MAX_SECONDARY_INDEXES_PER_COLLECTION {
        db_collection_index_reset(&collection.secondary_indexes[index_idx]);
        index_idx = index_idx + 1usize;
    }
    var row_idx: usize = 0usize;
    while row_idx < DB_MAX_ROWS_PER_COLLECTION {
        collection.rows[row_idx].present = false;
        collection.rows[row_idx].tombstone = false;
        collection.rows[row_idx].doc_id = 0u64;
        collection.rows[row_idx].record_ptr = record_pointer_make(0u32, 0u16);
        collection.rows[row_idx].doc_len = 0u16;
        row_idx = row_idx + 1usize;
    }
}

fn db_default_snapshot_policy() SnapshotPressurePolicy {
    return SnapshotPressurePolicy{
        soft_retired_bytes: 256u64,
        hard_retired_bytes: 1024u64,
        max_retired_views: 4u32,
        cursor_lease_ms: 30000u64,
    };
}

fn doc_blob_builder_drop(builder: DocBlobBuilder) void {
    _ = builder;
}

fn doc_blob_builder_init() DocBlobBuilder {
    return DocBlobBuilder{
        active: true,
        doc_len: 0u16,
        scratch: [],
        doc_blob: [],
    };
}

fn doc_blob_builder_build_json(builder: &DocBlobBuilder, json: &[const byte]) !void {
    if builder == null || !builder.active || json.ptr == null {
        return error.DbInvalidExpr;
    }
    var arena: Arena = Arena{ buffer: null, size: 0, used: 0 };
    arena_init(&arena, &builder.scratch[0], DB_TXN_DOC_SCRATCH_MAX);
    const value: JsonValue = try parse(&arena, json.ptr, json.len);
    const encoded_len: usize = try doc_encode_json_value(&value, builder.doc_blob[0: DB_DOC_BLOB_MAX]);
    builder.doc_len = (encoded_len as! u16) catch {
        return error.DbRowTooLarge;
    };
}

fn txn_drop(txn: Txn) void {
    if txn.active && !txn.committed && txn.db != null {
        const staged: !&CommitViewState = db_commit_view_state(txn.db, txn.view_slot);
        if staged.error_id == 0u32 {
            db_clear_commit_view_state(staged.value);
            db_refresh_snapshot_status(txn.db);
        }
        writer_lock_guard_release(&txn.writer_guard);
    }
}

fn db_collection_data_page_id(collection: &DbCollection) u32 {
    if collection == null {
        return 0u32;
    }
    if collection.primary_root_page != 0u32 {
        return collection.primary_root_page;
    }
    return 2u32 + collection.collection_id;
}

fn db_record_cell_encode(row: &DbStoredRow, now_ms: u64, out: &[byte]) !usize {
    if row == null || out.ptr == null || !row.present || row.doc_len as usize > DB_DOC_BLOB_MAX {
        return error.DbRowTooLarge;
    }
    const total_len: usize = RECORD_CELL_HEADER_SIZE + row.doc_len as usize;
    if total_len > out.len {
        return error.DbRowTooLarge;
    }
    db_store_u64_le(out, RECORD_CELL_DOC_ID_OFF, row.doc_id);
    db_store_u64_le(out, RECORD_CELL_CREATED_AT_OFF, now_ms);
    db_store_u64_le(out, RECORD_CELL_UPDATED_AT_OFF, now_ms);
    db_store_u32_le(out, RECORD_CELL_DOC_LEN_OFF, row.doc_len as u32);
    if row.doc_len > 0u16 {
        _ = mem_copy(&out.ptr[RECORD_CELL_HEADER_SIZE], &row.doc_blob[0], row.doc_len as usize);
    }
    return total_len;
}

fn db_record_cell_decode(cell: &[byte], row: &DbStoredRow) !void {
    if cell.ptr == null || row == null || cell.len < RECORD_CELL_HEADER_SIZE {
        return error.DbPageCorrupt;
    }
    const doc_len: usize = db_load_u32_le(cell, RECORD_CELL_DOC_LEN_OFF) as usize;
    if RECORD_CELL_HEADER_SIZE + doc_len > cell.len || doc_len > DB_DOC_BLOB_MAX {
        return error.DbPageCorrupt;
    }
    row.present = true;
    row.doc_id = db_load_u64_le(cell, RECORD_CELL_DOC_ID_OFF);
    row.doc_len = (doc_len as! u16) catch {
        return error.DbPageCorrupt;
    };
    if doc_len > 0usize {
        _ = mem_copy(&row.doc_blob[0], &cell.ptr[RECORD_CELL_HEADER_SIZE], doc_len);
    }
}

fn db_collection_encode_page(collection: &DbCollection, page_size: u32, now_ms: u64, out: &[byte]) !void {
    if collection == null || out.ptr == null || !page_buffer_size_matches(out, page_size) {
        return error.DbCollectionPageMissing;
    }
    try slotted_page_init(out, PageType.DATA);
    var row_idx: u16 = 0u16;
    while row_idx < collection.row_count {
        const row: &DbStoredRow = &collection.rows[row_idx as usize];
        if row.present {
            var cell_buf: [byte: RECORD_CELL_HEADER_SIZE + DB_DOC_BLOB_MAX] = [];
            const cell_len: usize = try db_record_cell_encode(row, now_ms, cell_buf[0: RECORD_CELL_HEADER_SIZE + DB_DOC_BLOB_MAX]);
            var flags: u16 = 0u16;
            if row.tombstone {
                flags = SLOT_FLAG_TOMBSTONE;
            }
            _ = try slotted_page_insert_copy_with_flags(out, cell_buf[0: cell_len], flags);
        }
        row_idx = row_idx + 1u16;
    }
}

fn db_collection_load_page(collection: &DbCollection, page_id: u32, page_buf: &[byte]) !void {
    if collection == null || page_buf.ptr == null {
        return error.DbCollectionPageMissing;
    }
    const header: &PageHeader = page_header_from_buf(page_buf);
    if header == null || header.page_type != PageType.DATA {
        return error.DbPageCorrupt;
    }
    const slot_count: u16 = slotted_page_slot_count(page_buf);
    collection.row_count = slot_count;
    var slot_idx: u16 = 0u16;
    while slot_idx < slot_count {
        const cell: SlottedPageCellView = slotted_page_cell_view(page_buf, slot_idx) catch {
            return error.DbPageCorrupt;
        };
        if slot_is_used(cell.flags) {
            if slot_idx as usize >= DB_MAX_ROWS_PER_COLLECTION {
                return error.DbRowFull;
            }
            const row: &DbStoredRow = &collection.rows[slot_idx as usize];
            try db_record_cell_decode(cell.ptr[0: cell.len], row);
            row.record_ptr = record_pointer_make(page_id, slot_idx);
            row.tombstone = slot_is_tombstone(cell.flags);
        }
        slot_idx = slot_idx + 1u16;
    }
}

fn db_rebuild_primary_index(db: &DbHandle, collection_slot: u16) !void {
    if db == null || collection_slot as usize >= DB_MAX_COLLECTIONS {
        return error.DbCollectionNotFound;
    }
    const slot_idx: usize = (collection_slot as! usize) catch {
        return error.DbCollectionNotFound;
    };
    if slot_idx >= DB_MAX_COLLECTIONS {
        return error.DbCollectionNotFound;
    }
    db.primary_indexes[slot_idx] = try primary_btree_init(256u32);
    const state: &CommitViewState = try db_current_view_state(db);
    const collection: &DbCollection = &state.collections[slot_idx];
    var row_idx: u16 = 0u16;
    while row_idx < collection.row_count {
        const row: &DbStoredRow = &collection.rows[row_idx as usize];
        if row.present && !row.tombstone {
            try primary_btree_insert(&db.primary_indexes[slot_idx], row.doc_id, &row.record_ptr);
        }
        row_idx = row_idx + 1u16;
    }
}

fn db_collection_secondary_index_meta(collection: &DbCollection, index_slot: u16) !&DbCollectionIndexMeta {
    if collection == null {
        return error.DbCollectionNotFound;
    }
    const idx: usize = (index_slot as! usize) catch {
        return error.DbCollectionNotFound;
    };
    if idx >= DB_MAX_SECONDARY_INDEXES_PER_COLLECTION || index_slot >= collection.secondary_index_count {
        return error.DbCollectionNotFound;
    }
    if idx >= DB_MAX_SECONDARY_INDEXES_PER_COLLECTION {
        return error.DbCollectionNotFound;
    }
    return &collection.secondary_indexes[idx];
}

fn db_secondary_index_compare_rows(collection: &DbCollection, index_state: &DbSecondaryIndexState, left_slot: u16, right_slot: u16) !i32 {
    const left_row: &DbStoredRow = try db_row_at(collection, left_slot);
    const right_row: &DbStoredRow = try db_row_at(collection, right_slot);
    const left_node: &[byte] = (path_program_eval(&index_state.path_program, try db_row_blob(left_row)) catch {
        return 0 - 1;
    });
    const right_node: &[byte] = (path_program_eval(&index_state.path_program, try db_row_blob(right_row)) catch {
        return 1;
    });
    const cmp: i32 = try doc_compare_scalar_nodes(left_node, right_node);
    if cmp != 0 {
        return cmp;
    }
    if left_row.doc_id < right_row.doc_id {
        return 0 - 1;
    }
    if left_row.doc_id > right_row.doc_id {
        return 1;
    }
    return 0;
}

fn db_rebuild_secondary_index(db: &DbHandle, collection_slot: u16, index_slot: u16) !void {
    const state: &CommitViewState = try db_current_view_state(db);
    const collection_idx: usize = (collection_slot as! usize) catch {
        return error.DbCollectionNotFound;
    };
    if collection_idx >= DB_MAX_COLLECTIONS {
        return error.DbCollectionNotFound;
    }
    const collection: &DbCollection = &state.collections[collection_idx];
    const meta: &DbCollectionIndexMeta = try db_collection_secondary_index_meta(collection, index_slot);
    const index_state: &DbSecondaryIndexState = try db_secondary_index_state(db, collection_slot, index_slot);
    db_secondary_index_state_reset(index_state);
    index_state.present = meta.present;
    index_state.index_id = meta.index_id;
    index_state.name_len = meta.name_len;
    index_state.path_len = meta.path_len;
    if meta.name_len > 0u16 {
        _ = mem_copy(&index_state.name[0], &meta.name[0], meta.name_len as usize);
    }
    if meta.path_len > 0u16 {
        _ = mem_copy(&index_state.path[0], &meta.path[0], meta.path_len as usize);
    }
    index_state.path_program = try path_program_compile(index_state.path[0: index_state.path_len as usize]);

    var row_idx: u16 = 0u16;
    while row_idx < collection.row_count {
        const row: &DbStoredRow = &collection.rows[row_idx as usize];
        if row.present && !row.tombstone {
            const node_union: !&[byte] = path_program_eval(&index_state.path_program, try db_row_blob(row));
            if node_union.error_id == 0u32 {
                const node: &[byte] = node_union.value;
                const tag: DocNodeTag = try doc_node_tag(node);
                if tag == DocNodeTag.NULL ||
                    tag == DocNodeTag.FALSE ||
                    tag == DocNodeTag.TRUE ||
                    tag == DocNodeTag.INT64 ||
                    tag == DocNodeTag.NUMBER_TEXT ||
                    tag == DocNodeTag.STRING {
                    index_state.row_slots[index_state.row_count as usize] = row_idx;
                    index_state.row_count = index_state.row_count + 1u16;
                }
            }
        }
        row_idx = row_idx + 1u16;
    }

    var i: u16 = 1u16;
    while i < index_state.row_count {
        const current: u16 = index_state.row_slots[i as usize];
        var j: usize = i as usize;
        while j > 0usize {
            const prev: u16 = index_state.row_slots[j - 1usize];
            const cmp: i32 = try db_secondary_index_compare_rows(collection, index_state, prev, current);
            if cmp <= 0 {
                break;
            }
            index_state.row_slots[j] = prev;
            j = j - 1usize;
        }
        index_state.row_slots[j] = current;
        i = i + 1u16;
    }
}

fn db_rebuild_secondary_indexes(db: &DbHandle, collection_slot: u16) !void {
    const state: &CommitViewState = try db_current_view_state(db);
    const collection: &DbCollection = try db_collection_at_in_state(state, collection_slot);
    var index_slot: u16 = 0u16;
    while index_slot < DB_MAX_SECONDARY_INDEXES_PER_COLLECTION as u16 {
        const index_state: &DbSecondaryIndexState = try db_secondary_index_state(db, collection_slot, index_slot);
        db_secondary_index_state_reset(index_state);
        index_slot = index_slot + 1u16;
    }
    index_slot = 0u16;
    while index_slot < collection.secondary_index_count {
        try db_rebuild_secondary_index(db, collection_slot, index_slot);
        index_slot = index_slot + 1u16;
    }
}

fn db_reload_from_disk(db: &DbHandle) !void {
    if db == null {
        return error.DbHandleInvalid;
    }
    const info: PagerOpenInfo = try pager_open_at_stem(db_stem_ptr(db));
    const snapshot: CatalogSnapshot = try catalog_load_at_stem(db_stem_ptr(db));
    var i: usize = 0usize;
    while i < DB_MAX_COMMIT_VIEWS {
        db_clear_commit_view_state(&db.commit_views[i]);
        i = i + 1usize;
    }
    var index_slot: usize = 0usize;
    while index_slot < DB_MAX_COLLECTIONS {
        db.primary_indexes[index_slot] = try primary_btree_init(256u32);
        index_slot = index_slot + 1usize;
    }
    index_slot = 0usize;
    while index_slot < DB_MAX_COLLECTIONS * DB_MAX_SECONDARY_INDEXES_PER_COLLECTION {
        db_secondary_index_state_reset(&db.secondary_indexes[index_slot]);
        index_slot = index_slot + 1usize;
    }
    const current: &CommitViewState = &db.commit_views[0usize];
    current.present = true;
    current.retired = false;
    current.reader_pins = 0u32;
    current.view = CommitView{
        generation: info.meta.commit_lsn + 1u64,
        commit_lsn: info.meta.commit_lsn,
        catalog_root: info.meta.catalog_root,
        page_count: info.meta.page_count,
        freelist_head: info.meta.freelist_head,
        page_table_gen: info.meta.commit_lsn + 1u64,
    };
    const view: CatalogView = try catalog_view_from_page(snapshot.page[0: snapshot.page_size as usize]);
    var collection_idx: u32 = 0u32;
    while collection_idx < view.root.collection_count {
        const entry: CatalogCollectionView = try catalog_collection_at(&view, collection_idx);
        const slot: usize = (collection_idx as! usize) catch {
            return error.DbCollectionFull;
        };
        if slot >= DB_MAX_COLLECTIONS {
            return error.DbCollectionFull;
        }
        db_collection_reset(&current.collections[slot]);
        current.collections[slot].present = true;
        current.collections[slot].collection_id = entry.meta.collection_id;
        current.collections[slot].next_doc_id = entry.meta.next_doc_id;
        current.collections[slot].primary_root_page = entry.meta.primary_root_page;
        current.collections[slot].secondary_index_count = entry.meta.secondary_index_count;
        try db_copy_name(entry.name, current.collections[slot].name[0: 64], &current.collections[slot].name_len);
        var collection_index_idx: u32 = 0u32;
        while collection_index_idx < entry.meta.secondary_index_count {
            const index_view: CatalogIndexView = try catalog_collection_index_at(&view, &entry, collection_index_idx);
            const index_slot_usize: usize = (collection_index_idx as! usize) catch {
                return error.DbCollectionFull;
            };
            if index_slot_usize >= DB_MAX_SECONDARY_INDEXES_PER_COLLECTION {
                return error.DbCollectionFull;
            }
            current.collections[slot].secondary_indexes[index_slot_usize].present = true;
            current.collections[slot].secondary_indexes[index_slot_usize].index_id = index_view.meta.index_id;
            current.collections[slot].secondary_indexes[index_slot_usize].root_page = index_view.meta.root_page;
            current.collections[slot].secondary_indexes[index_slot_usize].path_segment_count = index_view.meta.path_segment_count;
            try db_copy_name(index_view.name, current.collections[slot].secondary_indexes[index_slot_usize].name[0: 64], &current.collections[slot].secondary_indexes[index_slot_usize].name_len);
            try db_copy_path(index_view.path, current.collections[slot].secondary_indexes[index_slot_usize].path[0: 128], &current.collections[slot].secondary_indexes[index_slot_usize].path_len);
            collection_index_idx = collection_index_idx + 1u32;
        }
        const page_id: u32 = db_collection_data_page_id(&current.collections[slot]);
        if page_id >= 2u32 && page_id < info.meta.page_count {
            var raw_page: [byte: 8192] = [];
            const page_buf: &[byte] = raw_page[0: info.meta.page_size as usize];
            try pager_read_page_at_stem(db_stem_ptr(db), page_id, page_buf);
            try db_collection_load_page(&current.collections[slot], page_id, page_buf);
        }
        collection_idx = collection_idx + 1u32;
    }
    current.collection_count = (view.root.collection_count as! u16) catch {
        return error.DbCollectionFull;
    };
    db.current_view_slot = 0u16;
    db.next_view_generation = current.view.generation + 1u64;
    db.next_page_table_gen = current.view.page_table_gen + 1u64;
    collection_idx = 0u32;
    while collection_idx < view.root.collection_count {
        try db_rebuild_primary_index(db, collection_idx as u16);
        try db_rebuild_secondary_indexes(db, collection_idx as u16);
        collection_idx = collection_idx + 1u32;
    }
    db_refresh_snapshot_status(db);
}

fn db_check_meta_state_valid(meta: &MetaPage) bool {
    return meta != null &&
        meta.page_count >= 3u32 &&
        meta.catalog_root >= 2u32 &&
        meta.catalog_root < meta.page_count &&
        meta.checkpoint_lsn <= meta.commit_lsn;
}

fn db_check_validate_collection_rows(collection: &DbCollection, expected_next_doc_id: u64, row_count_out: &u32) !void {
    if collection == null || row_count_out == null {
        return error.DbPageCorrupt;
    }
    var tree: PrimaryBTree = primary_btree_init(256u32) catch {
        return error.DbPageCorrupt;
    };
    var max_doc_id: u64 = 0u64;
    var row_idx: u16 = 0u16;
    while row_idx < collection.row_count {
        const row: &DbStoredRow = &collection.rows[row_idx as usize];
        if !row.present ||
            row.record_ptr.page_id != db_collection_data_page_id(collection) ||
            row.record_ptr.slot_id != row_idx {
            return error.DbPageCorrupt;
        }
        const blob: &[byte] = db_row_blob(row) catch {
            return error.DbPageCorrupt;
        };
        _ = doc_node_tag(blob) catch {
            return error.DbPageCorrupt;
        };
        if row.doc_id > max_doc_id {
            max_doc_id = row.doc_id;
        }
        if !row.tombstone {
            _ = primary_btree_insert(&tree, row.doc_id, &row.record_ptr) catch {
                return error.DbPageCorrupt;
            };
            const found: RecordPointer = primary_btree_lookup(&tree, row.doc_id) catch {
                return error.DbPageCorrupt;
            };
            if found.page_id != row.record_ptr.page_id || found.slot_id != row.record_ptr.slot_id {
                return error.DbPageCorrupt;
            }
            row_count_out[0] = row_count_out[0] + 1u32;
        }
        row_idx = row_idx + 1u16;
    }
    if expected_next_doc_id != max_doc_id + 1u64 {
        return error.DbPageCorrupt;
    }
}

fn db_check_collection_at_stem(stem: &const byte, page_size: u32, entry: &CatalogCollectionView, row_count_out: &u32) !void {
    if stem == null || entry == null || row_count_out == null {
        return error.DbPageCorrupt;
    }
    if entry.meta.primary_root_page < 2u32 {
        return error.DbCollectionPageMissing;
    }
    var raw_page: [byte: 8192] = [];
    const page_buf: &[byte] = raw_page[0: page_size as usize];
    try pager_read_page_at_stem(stem, entry.meta.primary_root_page, page_buf);

    var collection: DbCollection = DbCollection{
        present: true,
        collection_id: entry.meta.collection_id,
        name_len: 0u16,
        name: [],
        next_doc_id: entry.meta.next_doc_id,
        primary_root_page: entry.meta.primary_root_page,
        secondary_index_count: 0u16,
        secondary_indexes: [],
        row_count: 0u16,
        rows: [],
    };
    try db_copy_name(entry.name, collection.name[0: 64], &collection.name_len);
    try db_collection_load_page(&collection, entry.meta.primary_root_page, page_buf);
    try db_check_validate_collection_rows(&collection, entry.meta.next_doc_id, row_count_out);
}

fn db_zero_commit_view() CommitView {
    return CommitView{
        generation: 0u64,
        commit_lsn: 0u64,
        catalog_root: 0u32,
        page_count: 0u32,
        freelist_head: 0u32,
        page_table_gen: 0u64,
    };
}

fn db_clear_commit_view_state(state: &CommitViewState) void {
    if state == null {
        return;
    }
    state.present = false;
    state.retired = false;
    state.reader_pins = 0u32;
    state.retained_bytes = 0u64;
    state.view = db_zero_commit_view();
    state.collection_count = 0u16;
    var collection_idx: usize = 0usize;
    while collection_idx < DB_MAX_COLLECTIONS {
        db_collection_reset(&state.collections[collection_idx]);
        collection_idx = collection_idx + 1usize;
    }
}

fn db_commit_view_state(db: &DbHandle, view_slot: u16) !&CommitViewState {
    if db == null {
        return error.DbHandleInvalid;
    }
    const view_idx: usize = (view_slot as! usize) catch {
        return error.DbHandleInvalid;
    };
    if view_idx >= DB_MAX_COMMIT_VIEWS {
        return error.DbHandleInvalid;
    }
    const state: &CommitViewState = &db.commit_views[view_idx];
    if !state.present {
        return error.DbHandleInvalid;
    }
    return state;
}

fn db_current_view_state(db: &DbHandle) !&CommitViewState {
    if db == null {
        return error.DbHandleInvalid;
    }
    return db_commit_view_state(db, db.current_view_slot);
}

fn db_effective_snapshot_status(db: &DbHandle) SnapshotPressureStatus {
    if db != null && db.snapshot_status_override_enabled {
        return db.snapshot_status_override;
    }
    if db == null {
        return SnapshotPressureStatus{
            retired_bytes: 0u64,
            retired_views: 0u32,
        };
    }
    return db.snapshot_status;
}

fn db_compute_view_page_count(state: &CommitViewState) u32 {
    if state == null || !state.present {
        return 0u32;
    }
    var total: u32 = 0u32;
    var i: u16 = 0u16;
    while i < state.collection_count {
        if state.collections[i as usize].present {
            total = total + state.collections[i as usize].row_count as u32;
        }
        i = i + 1u16;
    }
    return total;
}

fn db_compute_view_retained_bytes(state: &CommitViewState) u64 {
    if state == null || !state.present {
        return 0u64;
    }
    var total: u64 = DB_VIEW_BASE_RETAINED_BYTES;
    var i: u16 = 0u16;
    while i < state.collection_count {
        const collection: &DbCollection = &state.collections[i as usize];
        if collection.present {
            total = total + DB_COLLECTION_RETAINED_BYTES;
            var row_idx: u16 = 0u16;
            while row_idx < collection.row_count {
                const row: &DbStoredRow = &collection.rows[row_idx as usize];
                if row.present {
                    total = total + DB_ROW_RETAINED_BYTES + row.doc_len as u64;
                }
                row_idx = row_idx + 1u16;
            }
        }
        i = i + 1u16;
    }
    return total;
}

fn db_finalize_view_state(state: &CommitViewState) void {
    if state == null || !state.present {
        return;
    }
    state.retained_bytes = db_compute_view_retained_bytes(state);
}

fn db_refresh_snapshot_status(db: &DbHandle) void {
    if db == null {
        return;
    }
    var retired_bytes: u64 = 0u64;
    var retired_views: u32 = 0u32;
    var i: usize = 0usize;
    while i < DB_MAX_COMMIT_VIEWS {
        const state: &CommitViewState = &db.commit_views[i];
        if state.present && state.retired {
            retired_views = retired_views + 1u32;
            retired_bytes = retired_bytes + state.retained_bytes;
        }
        i = i + 1usize;
    }
    db.snapshot_status = SnapshotPressureStatus{
        retired_bytes: retired_bytes,
        retired_views: retired_views,
    };
}

fn db_cleanup_retired_views(db: &DbHandle) void {
    if db == null {
        return;
    }
    var i: usize = 0usize;
    while i < DB_MAX_COMMIT_VIEWS {
        const state: &CommitViewState = &db.commit_views[i];
        if state.present && state.retired && state.reader_pins == 0u32 {
            db_clear_commit_view_state(state);
        }
        i = i + 1usize;
    }
    db_refresh_snapshot_status(db);
}

fn db_allocate_view_slot(db: &DbHandle) !u16 {
    if db == null {
        return error.DbHandleInvalid;
    }
    db_cleanup_retired_views(db);
    var i: usize = 0usize;
    while i < DB_MAX_COMMIT_VIEWS {
        if !db.commit_views[i].present {
            return (i as! u16) catch {
                return error.SnapshotPressure;
            };
        }
        i = i + 1usize;
    }
    return error.SnapshotPressure;
}

fn db_stage_view_from_current(db: &DbHandle) !u16 {
    if db == null {
        return error.DbHandleInvalid;
    }
    db_cleanup_retired_views(db);
    const effective_status: SnapshotPressureStatus = db_effective_snapshot_status(db);
    try snapshot_pressure_require_write_ok(&db.snapshot_policy, &effective_status);
    const source: &CommitViewState = try db_current_view_state(db);
    const new_slot: u16 = try db_allocate_view_slot(db);
    const new_idx: usize = (new_slot as! usize) catch {
        return error.SnapshotPressure;
    };
    if new_idx >= DB_MAX_COMMIT_VIEWS {
        return error.SnapshotPressure;
    }
    const target: &CommitViewState = &db.commit_views[new_idx];
    db_clear_commit_view_state(target);
    target.present = true;
    target.retired = false;
    target.reader_pins = 0u32;
    target.retained_bytes = 0u64;
    target.view = CommitView{
        generation: db.next_view_generation,
        commit_lsn: db.next_view_generation,
        catalog_root: source.view.catalog_root,
        page_count: source.view.page_count,
        freelist_head: source.view.freelist_head,
        page_table_gen: db.next_page_table_gen,
    };
    target.collection_count = source.collection_count;
    var i: u16 = 0u16;
    while i < source.collection_count {
        target.collections[i as usize] = source.collections[i as usize];
        i = i + 1u16;
    }
    return new_slot;
}

fn db_publish_view_slot(db: &DbHandle, new_slot: u16) !void {
    if db == null {
        return error.DbHandleInvalid;
    }
    const new_state: &CommitViewState = try db_commit_view_state(db, new_slot);
    db_finalize_view_state(new_state);
    const old_slot: u16 = db.current_view_slot;
    db.current_view_slot = new_slot;
    if (old_slot as usize) < DB_MAX_COMMIT_VIEWS {
        const old_state: &CommitViewState = &db.commit_views[old_slot as usize];
        if old_state.present {
            old_state.retired = true;
        }
    }
    db.next_view_generation = db.next_view_generation + 1u64;
    db.next_page_table_gen = db.next_page_table_gen + 1u64;
    db_cleanup_retired_views(db);
}

fn db_find_collection_slot_by_id_in_view(db: &DbHandle, view_slot: u16, collection_id: u32) !u16 {
    const state: &CommitViewState = try db_commit_view_state(db, view_slot);
    var i: u16 = 0u16;
    while i < state.collection_count {
        if state.collections[i as usize].present && state.collections[i as usize].collection_id == collection_id {
            return i;
        }
        i = i + 1u16;
    }
    return error.DbCollectionNotFound;
}

fn db_find_collection_slot_by_name_in_view(db: &DbHandle, view_slot: u16, name: &[const byte]) !u16 {
    if db == null || name.ptr == null {
        return error.DbCollectionNotFound;
    }
    const state: &CommitViewState = try db_commit_view_state(db, view_slot);
    var i: u16 = 0u16;
    while i < state.collection_count {
        const col: &DbCollection = &state.collections[i as usize];
        if col.present && col.name_len as usize == name.len {
            var same: bool = true;
            var j: usize = 0usize;
            while j < name.len {
                if col.name[j] != name.ptr[j] {
                    same = false;
                    break;
                }
                j = j + 1usize;
            }
            if same {
                return i;
            }
        }
        i = i + 1u16;
    }
    return error.DbCollectionNotFound;
}

fn db_find_collection_slot_by_id(db: &DbHandle, collection_id: u32) !u16 {
    if db == null {
        return error.DbHandleInvalid;
    }
    return db_find_collection_slot_by_id_in_view(db, db.current_view_slot, collection_id);
}

fn db_find_collection_slot_by_name(db: &DbHandle, name: &[const byte]) !u16 {
    if db == null {
        return error.DbCollectionNotFound;
    }
    return db_find_collection_slot_by_name_in_view(db, db.current_view_slot, name);
}

fn db_row_blob(row: &DbStoredRow) !&[byte] {
    if row == null || !row.present || row.tombstone || row.doc_len as usize > DB_DOC_BLOB_MAX {
        return error.DbRowTooLarge;
    }
    return row.doc_blob[0: row.doc_len as usize];
}

fn db_collection_row_ref(db: &DbHandle, view_slot: u16, collection_slot: u16, row_slot: u16) !RowRef {
    if db == null || collection_slot as usize >= DB_MAX_COLLECTIONS {
        return error.DbCollectionNotFound;
    }
    const state: &CommitViewState = try db_commit_view_state(db, view_slot);
    const collection_idx: usize = (collection_slot as! usize) catch {
        return error.DbCollectionNotFound;
    };
    if collection_idx >= DB_MAX_COLLECTIONS {
        return error.DbCollectionNotFound;
    }
    const collection: &DbCollection = &state.collections[collection_idx];
    if !collection.present || row_slot >= collection.row_count || row_slot as usize >= DB_MAX_ROWS_PER_COLLECTION {
        return error.DbCollectionNotFound;
    }
    const row_idx: usize = (row_slot as! usize) catch {
        return error.DbCollectionNotFound;
    };
    if row_idx >= DB_MAX_ROWS_PER_COLLECTION {
        return error.DbCollectionNotFound;
    }
    const row: &DbStoredRow = &collection.rows[row_idx];
    if row.tombstone {
        return error.DbCollectionNotFound;
    }
    return RowRef{
        doc_id: row.doc_id,
        record_ptr: row.record_ptr,
        doc_blob: try db_row_blob(row),
    };
}

fn db_pin_current_view_slot(db: &DbHandle) !u16 {
    const state: &CommitViewState = try db_current_view_state(db);
    state.reader_pins = state.reader_pins + 1u32;
    return db.current_view_slot;
}

fn db_unpin_view_slot(db: &DbHandle, view_slot: u16) void {
    if db == null {
        return;
    }
    const view_idx: usize = (view_slot as! usize) catch {
        return;
    };
    if view_idx >= DB_MAX_COMMIT_VIEWS {
        return;
    }
    const state: &CommitViewState = &db.commit_views[view_idx];
    if state.present && state.reader_pins > 0u32 {
        state.reader_pins = state.reader_pins - 1u32;
    }
    db_cleanup_retired_views(db);
}

fn commit_view_pin_release(pin: &CommitViewPin) void {
    if pin == null || !pin.held {
        return;
    }
    if pin.release_counter != null {
        pin.release_counter[0] = pin.release_counter[0] + 1;
    }
    db_unpin_view_slot(pin.db, pin.view_slot);
    pin.held = false;
}

fn commit_view_pin_drop(pin: CommitViewPin) void {
    if !pin.held {
        return;
    }
    if pin.release_counter != null {
        pin.release_counter[0] = pin.release_counter[0] + 1;
    }
    db_unpin_view_slot(pin.db, pin.view_slot);
}

export fn commit_view_pin_is_held(pin: &CommitViewPin) bool {
    return pin != null && pin.held;
}

fn query_cursor_drop(cursor: QueryCursor) void {
    if cursor.release_counter != null && (cursor.has_current || cursor.pin.held) {
        cursor.release_counter[0] = cursor.release_counter[0] + 1;
    }
}

export fn query_cursor_is_open(cursor: &QueryCursor) bool {
    return cursor != null && commit_view_pin_is_held(&cursor.pin);
}

export fn query_cursor_commit_view(cursor: &QueryCursor) CommitView {
    if cursor == null {
        return db_zero_commit_view();
    }
    return cursor.pin.view;
}

fn exec_copy_text(text: &[const byte], out: &[byte], len_out: &u16) !void {
    if text.ptr == null || out.ptr == null || len_out == null || text.len > 2048usize {
        return error.DbResultTooLarge;
    }
    len_out[0] = (text.len as! u16) catch {
        return error.DbResultTooLarge;
    };
    if text.len > 0 {
        _ = mem_copy(out.ptr, text.ptr, text.len);
    }
}

fn exec_value_from_literal(literal: &BoundLiteral) !ExecValue {
    if literal == null {
        return error.DbInvalidExpr;
    }
    var out: ExecValue = ExecValue{
        kind: ExecValueKind.NULL,
        bool_value: false,
        i64_value: 0i64,
        u64_value: 0u64,
        text_len: 0u16,
        text: [],
        doc_node: &""[0: 0],
    };
    if literal.kind == BoundLiteralKind.NULL {
        out.kind = ExecValueKind.NULL;
        return out;
    }
    if literal.kind == BoundLiteralKind.BOOL {
        out.kind = ExecValueKind.BOOL;
        out.bool_value = literal.bool_value;
        return out;
    }
    if literal.kind == BoundLiteralKind.INT64 {
        out.kind = ExecValueKind.INT64;
        out.i64_value = literal.i64_value;
        return out;
    }
    if literal.kind == BoundLiteralKind.UINT64 {
        out.kind = ExecValueKind.UINT64;
        out.u64_value = literal.u64_value;
        return out;
    }
    if literal.kind == BoundLiteralKind.NUMBER_TEXT {
        out.kind = ExecValueKind.NUMBER_TEXT;
        out.text_len = literal.text_len;
        if literal.text_len > 0u16 {
            _ = mem_copy(&out.text[0], &literal.text[0], literal.text_len as usize);
        }
        return out;
    }
    out.kind = ExecValueKind.STRING;
    out.text_len = literal.text_len;
    if literal.text_len > 0u16 {
        _ = mem_copy(&out.text[0], &literal.text[0], literal.text_len as usize);
    }
    return out;
}

fn exec_encode_u64_text(value: u64, out: &[byte]) !usize {
    var digits: [byte: 32] = [];
    var tmp: u64 = value;
    var len: usize = 0usize;
    if tmp == 0u64 {
        digits[0] = 48 as byte;
        len = 1usize;
    } else {
        while tmp > 0u64 {
            if len >= @len(digits) {
                return error.DbResultTooLarge;
            }
            digits[len] = ((48u64 + (tmp % 10u64)) as! byte).value;
            len = len + 1usize;
            tmp = tmp / 10u64;
        }
    }
    if out.ptr == null || len > out.len {
        return error.DbResultTooLarge;
    }
    var i: usize = 0usize;
    while len > 0usize {
        len = len - 1usize;
        out.ptr[i] = digits[len];
        i = i + 1usize;
    }
    return i;
}

fn exec_value_encode_doc(value: &ExecValue, out: &[byte]) !usize {
    if value == null || out.ptr == null {
        return error.DbInvalidExpr;
    }
    if value.kind == ExecValueKind.DOC_NODE {
        if value.doc_node.len > out.len {
            return error.DbResultTooLarge;
        }
        if value.doc_node.len > 0 {
            _ = mem_copy(out.ptr, value.doc_node.ptr, value.doc_node.len);
        }
        return value.doc_node.len;
    }
    if value.kind == ExecValueKind.INT64 {
        return try doc_encode_int64_node(value.i64_value, out);
    }
    if value.kind == ExecValueKind.NUMBER_TEXT {
        return try doc_encode_number_text_node(value.text[0: value.text_len as usize], out);
    }
    if value.kind == ExecValueKind.STRING {
        return try doc_encode_string_node(value.text[0: value.text_len as usize], out);
    }
    if value.kind == ExecValueKind.UINT64 {
        if value.u64_value <= 9223372036854775807u64 {
            return try doc_encode_int64_node(value.u64_value as i64, out);
        }
        var text_buf: [byte: 32] = [];
        const text_len: usize = try exec_encode_u64_text(value.u64_value, text_buf[0: 32]);
        return try doc_encode_number_text_node(text_buf[0: text_len], out);
    }
    if value.kind == ExecValueKind.BOOL {
        const bool_value: JsonValue = JsonValue.bool_val(value.bool_value);
        return try doc_encode_json_value(&bool_value, out);
    }
    const null_value: JsonValue = JsonValue.json_null();
    return try doc_encode_json_value(&null_value, out);
}

fn exec_compare_doc_id_literal(doc_id: u64, literal: &BoundLiteral) !i32 {
    if literal == null {
        return error.DbInvalidExpr;
    }
    if literal.kind == BoundLiteralKind.UINT64 {
        if doc_id < literal.u64_value {
            return 0 - 1;
        }
        if doc_id > literal.u64_value {
            return 1;
        }
        return 0;
    }
    if literal.kind == BoundLiteralKind.INT64 {
        if literal.i64_value < 0i64 {
            return 1;
        }
        const rhs: u64 = (literal.i64_value as! u64) catch {
            return error.DbInvalidExpr;
        };
        if doc_id < rhs {
            return 0 - 1;
        }
        if doc_id > rhs {
            return 1;
        }
        return 0;
    }
    if literal.kind == BoundLiteralKind.NUMBER_TEXT {
        var left_text: [byte: 32] = [];
        const left_len: usize = try exec_encode_u64_text(doc_id, left_text[0: 32]);
        return try doc_compare_number_lexemes(left_text[0: left_len], literal.text[0: literal.text_len as usize]);
    }
    return error.DbInvalidExpr;
}

fn exec_compare_values(left: &ExecValue, right: &ExecValue) !i32 {
    var left_buf: [byte: 4096] = [];
    var right_buf: [byte: 4096] = [];
    const left_len: usize = try exec_value_encode_doc(left, left_buf[0: 4096]);
    const right_len: usize = try exec_value_encode_doc(right, right_buf[0: 4096]);
    return try doc_compare_scalar_nodes(left_buf[0: left_len], right_buf[0: right_len]);
}

fn db_eval_value(db: &DbHandle, bound: &BoundSelect, row: &RowRef, expr_index: i16) !ExecValue {
    const expr: &BoundExprNode = try bound_expr_node(bound, expr_index);
    if expr.kind == BoundExprKind.SYSTEM_ID {
        return ExecValue{
            kind: ExecValueKind.UINT64,
            bool_value: false,
            i64_value: 0i64,
            u64_value: row.doc_id,
            text_len: 0u16,
            text: [],
            doc_node: &""[0: 0],
        };
    }
    if expr.kind == BoundExprKind.PATH {
        const node: &[byte] = (path_program_eval(&expr.path.program, row.doc_blob) catch {
            return error.DbPathError;
        });
        return ExecValue{
            kind: ExecValueKind.DOC_NODE,
            bool_value: false,
            i64_value: 0i64,
            u64_value: 0u64,
            text_len: 0u16,
            text: [],
            doc_node: node,
        };
    }
    if expr.kind == BoundExprKind.LITERAL {
        return try exec_value_from_literal(&expr.literal);
    }
    if expr.kind == BoundExprKind.UNARY {
        const child: ExecValue = try db_eval_value(db, bound, row, expr.left);
        if expr.unary_op == SqlUnaryOp.NOT {
            const result: bool = (try db_eval_predicate(db, bound, row, expr.left)) == false;
            return ExecValue{
                kind: ExecValueKind.BOOL,
                bool_value: result,
                i64_value: 0i64,
                u64_value: 0u64,
                text_len: 0u16,
                text: [],
                doc_node: &""[0: 0],
            };
        }
        if child.kind == ExecValueKind.INT64 {
            return ExecValue{
                kind: ExecValueKind.INT64,
                bool_value: false,
                i64_value: 0i64 - child.i64_value,
                u64_value: 0u64,
                text_len: 0u16,
                text: [],
                doc_node: &""[0: 0],
            };
        }
        if child.kind == ExecValueKind.UINT64 {
            return ExecValue{
                kind: ExecValueKind.INT64,
                bool_value: false,
                i64_value: 0i64 - child.u64_value as i64,
                u64_value: 0u64,
                text_len: 0u16,
                text: [],
                doc_node: &""[0: 0],
            };
        }
        return error.DbInvalidExpr;
    }
    if expr.kind == BoundExprKind.IS_NULL {
        const result_union: !ExecValue = db_eval_value(db, bound, row, expr.left);
        if result_union.error_id != 0u32 {
            if result_union.error_id == @error_id(error.DbPathError) {
                return ExecValue{
                    kind: ExecValueKind.BOOL,
                    bool_value: true,
                    i64_value: 0i64,
                    u64_value: 0u64,
                    text_len: 0u16,
                    text: [],
                    doc_node: &""[0: 0],
                };
            }
            return error.DbInvalidExpr;
        }
        const result: ExecValue = result_union.value;
        return ExecValue{
            kind: ExecValueKind.BOOL,
            bool_value: result.kind == ExecValueKind.NULL,
            i64_value: 0i64,
            u64_value: 0u64,
            text_len: 0u16,
            text: [],
            doc_node: &""[0: 0],
        };
    }
    if expr.kind == BoundExprKind.BINARY {
        if expr.binary_op == SqlBinaryOp.AND || expr.binary_op == SqlBinaryOp.OR {
            const left_bool: bool = try db_eval_predicate(db, bound, row, expr.left);
            if expr.binary_op == SqlBinaryOp.AND {
                if !left_bool {
                    return ExecValue{
                        kind: ExecValueKind.BOOL,
                        bool_value: false,
                        i64_value: 0i64,
                        u64_value: 0u64,
                        text_len: 0u16,
                        text: [],
                        doc_node: &""[0: 0],
                    };
                }
                const right_bool: bool = try db_eval_predicate(db, bound, row, expr.right);
                return ExecValue{
                    kind: ExecValueKind.BOOL,
                    bool_value: right_bool,
                    i64_value: 0i64,
                    u64_value: 0u64,
                    text_len: 0u16,
                    text: [],
                    doc_node: &""[0: 0],
                };
            }
            if left_bool {
                return ExecValue{
                    kind: ExecValueKind.BOOL,
                    bool_value: true,
                    i64_value: 0i64,
                    u64_value: 0u64,
                    text_len: 0u16,
                    text: [],
                    doc_node: &""[0: 0],
                };
            }
            const right_bool: bool = try db_eval_predicate(db, bound, row, expr.right);
            return ExecValue{
                kind: ExecValueKind.BOOL,
                bool_value: right_bool,
                i64_value: 0i64,
                u64_value: 0u64,
                text_len: 0u16,
                text: [],
                doc_node: &""[0: 0],
            };
        }
        const left_node: &BoundExprNode = try bound_expr_node(bound, expr.left);
        const right_node: &BoundExprNode = try bound_expr_node(bound, expr.right);
        var cmp: i32 = 0;
        if left_node.kind == BoundExprKind.SYSTEM_ID && right_node.kind == BoundExprKind.LITERAL {
            cmp = try exec_compare_doc_id_literal(row.doc_id, &right_node.literal);
        } else if right_node.kind == BoundExprKind.SYSTEM_ID && left_node.kind == BoundExprKind.LITERAL {
            cmp = 0 - (try exec_compare_doc_id_literal(row.doc_id, &left_node.literal));
        } else {
            const left_value: ExecValue = try db_eval_value(db, bound, row, expr.left);
            const right_value: ExecValue = try db_eval_value(db, bound, row, expr.right);
            cmp = try exec_compare_values(&left_value, &right_value);
        }
        var ok: bool = false;
        if expr.binary_op == SqlBinaryOp.EQ {
            ok = cmp == 0;
        } else if expr.binary_op == SqlBinaryOp.NE {
            ok = cmp != 0;
        } else if expr.binary_op == SqlBinaryOp.LT {
            ok = cmp < 0;
        } else if expr.binary_op == SqlBinaryOp.LE {
            ok = cmp <= 0;
        } else if expr.binary_op == SqlBinaryOp.GT {
            ok = cmp > 0;
        } else if expr.binary_op == SqlBinaryOp.GE {
            ok = cmp >= 0;
        }
        return ExecValue{
            kind: ExecValueKind.BOOL,
            bool_value: ok,
            i64_value: 0i64,
            u64_value: 0u64,
            text_len: 0u16,
            text: [],
            doc_node: &""[0: 0],
        };
    }
    return error.DbInvalidExpr;
}

fn db_eval_predicate(db: &DbHandle, bound: &BoundSelect, row: &RowRef, expr_index: i16) !bool {
    const value: ExecValue = try db_eval_value(db, bound, row, expr_index);
    if value.kind != ExecValueKind.BOOL {
        return error.DbInvalidExpr;
    }
    return value.bool_value;
}

fn db_exec_value_null() ExecValue {
    return ExecValue{
        kind: ExecValueKind.NULL,
        bool_value: false,
        i64_value: 0i64,
        u64_value: 0u64,
        text_len: 0u16,
        text: [],
        doc_node: &""[0: 0],
    };
}

fn db_eval_sort_value(db: &DbHandle, bound: &BoundSelect, row: &RowRef, expr_index: i16) !ExecValue {
    const value_union: !ExecValue = db_eval_value(db, bound, row, expr_index);
    if value_union.error_id != 0u32 {
        if value_union.error_id == @error_id(error.DbPathError) {
            return db_exec_value_null();
        }
        return error.DbInvalidExpr;
    }
    return value_union.value;
}

fn db_compare_rows_for_sort(db: &DbHandle, bound: &BoundSelect, view_slot: u16, collection_slot: u16, left_slot: u16, right_slot: u16, order_expr: i16, order_desc: bool) !i32 {
    const left_row: RowRef = try db_collection_row_ref(db, view_slot, collection_slot, left_slot);
    const right_row: RowRef = try db_collection_row_ref(db, view_slot, collection_slot, right_slot);
    const left_value: ExecValue = try db_eval_sort_value(db, bound, &left_row, order_expr);
    const right_value: ExecValue = try db_eval_sort_value(db, bound, &right_row, order_expr);
    const cmp: i32 = try exec_compare_values(&left_value, &right_value);
    if cmp < 0 {
        if order_desc {
            return 1;
        }
        return 0 - 1;
    }
    if cmp > 0 {
        if order_desc {
            return 0 - 1;
        }
        return 1;
    }
    if left_row.doc_id < right_row.doc_id {
        return 0 - 1;
    }
    if left_row.doc_id > right_row.doc_id {
        return 1;
    }
    return 0;
}

fn db_result_cell_append(row: &OwnedRow, cursor: &usize, kind: ResultCellKind, payload: &[byte]) !void {
    const total: usize = RESULT_CELL_HEADER_SIZE + payload.len;
    if row == null || cursor == null || cursor[0] + total > OWNED_ROW_MAX_BLOB {
        return error.DbResultTooLarge;
    }
    db_store_u16_le(row.result_blob[0: OWNED_ROW_MAX_BLOB], cursor[0], kind as u16);
    db_store_u16_le(row.result_blob[0: OWNED_ROW_MAX_BLOB], cursor[0] + 2usize, (payload.len as! u16) catch {
        return error.DbResultTooLarge;
    });
    cursor[0] = cursor[0] + RESULT_CELL_HEADER_SIZE;
    if payload.len > 0 {
        _ = mem_copy(&row.result_blob[cursor[0]], payload.ptr, payload.len);
    }
    cursor[0] = cursor[0] + payload.len;
}

fn db_build_single_text_result_with_allocator(text: &[const byte], allocator: IAllocator) !QueryResult {
    const row_bytes: usize = (@size_of(OwnedRow) as! usize).value;
    const row_mem: !&byte = allocator.alloc(row_bytes);
    if row_mem.error_id != 0u32 {
        return error.DbResultTooLarge;
    }
    const mem: &byte = row_mem.value;
    _ = mem_set(mem, 0 as byte, row_bytes);
    const row: &OwnedRow = mem as &OwnedRow;
    var cursor: usize = RESULT_BLOB_HEADER_SIZE;
    db_store_u16_le(row.result_blob[0: OWNED_ROW_MAX_BLOB], 0usize, 1u16);
    try db_result_cell_append(row, &cursor, ResultCellKind.STRING, text as &[byte]);
    row.result_len = (cursor as! u16) catch {
        allocator.dealloc(mem);
        return error.DbResultTooLarge;
    };
    return QueryResult{
        allocator: allocator,
        column_count: 1u16,
        row_count: 1u32,
        rows: row,
    };
}

fn db_project_exec_value(row: &OwnedRow, cursor: &usize, value: &ExecValue) !void {
    if value == null {
        return error.DbInvalidProjection;
    }
    if value.kind == ExecValueKind.NULL {
        try db_result_cell_append(row, cursor, ResultCellKind.NULL, &""[0: 0]);
        return;
    }
    if value.kind == ExecValueKind.BOOL {
        var b: [byte: 1] = [];
        if value.bool_value {
            b[0] = 1 as byte;
        } else {
            b[0] = 0 as byte;
        }
        try db_result_cell_append(row, cursor, ResultCellKind.BOOL, b[0: 1]);
        return;
    }
    if value.kind == ExecValueKind.INT64 {
        var buf: [byte: 8] = [];
        db_store_u64_le(buf[0: 8], 0usize, value.i64_value as u64);
        try db_result_cell_append(row, cursor, ResultCellKind.INT64, buf[0: 8]);
        return;
    }
    if value.kind == ExecValueKind.UINT64 {
        var buf: [byte: 8] = [];
        db_store_u64_le(buf[0: 8], 0usize, value.u64_value);
        try db_result_cell_append(row, cursor, ResultCellKind.UINT64, buf[0: 8]);
        return;
    }
    if value.kind == ExecValueKind.NUMBER_TEXT {
        try db_result_cell_append(row, cursor, ResultCellKind.NUMBER_TEXT, value.text[0: value.text_len as usize]);
        return;
    }
    if value.kind == ExecValueKind.STRING {
        try db_result_cell_append(row, cursor, ResultCellKind.STRING, value.text[0: value.text_len as usize]);
        return;
    }
    const tag: DocNodeTag = try doc_node_tag(value.doc_node);
    if tag == DocNodeTag.NULL {
        try db_result_cell_append(row, cursor, ResultCellKind.NULL, &""[0: 0]);
        return;
    }
    if tag == DocNodeTag.TRUE || tag == DocNodeTag.FALSE {
        var b: [byte: 1] = [];
        if try doc_bool_value(value.doc_node) {
            b[0] = 1 as byte;
        } else {
            b[0] = 0 as byte;
        }
        try db_result_cell_append(row, cursor, ResultCellKind.BOOL, b[0: 1]);
        return;
    }
    if tag == DocNodeTag.INT64 {
        var buf: [byte: 8] = [];
        db_store_u64_le(buf[0: 8], 0usize, (try doc_int64_value(value.doc_node)) as u64);
        try db_result_cell_append(row, cursor, ResultCellKind.INT64, buf[0: 8]);
        return;
    }
    if tag == DocNodeTag.NUMBER_TEXT {
        try db_result_cell_append(row, cursor, ResultCellKind.NUMBER_TEXT, try doc_number_text_lexeme_view(value.doc_node));
        return;
    }
    if tag == DocNodeTag.STRING {
        try db_result_cell_append(row, cursor, ResultCellKind.STRING, try doc_string_view(value.doc_node));
        return;
    }
    return error.DbScalarExpected;
}

fn db_project_row(bound: &BoundSelect, rowref: &RowRef, out_row: &OwnedRow) !void {
    if bound == null || rowref == null || out_row == null {
        return error.DbInvalidProjection;
    }
    _ = mem_set(&out_row.result_blob[0], 0 as byte, OWNED_ROW_MAX_BLOB);
    var cursor: usize = RESULT_BLOB_HEADER_SIZE;
    db_store_u16_le(out_row.result_blob[0: OWNED_ROW_MAX_BLOB], 0usize, bound.projection_count);
    var i: usize = 0usize;
    while i < bound.projection_count as usize {
        const value: ExecValue = try db_eval_value(null, bound, rowref, bound.projection_exprs[i]);
        try db_project_exec_value(out_row, &cursor, &value);
        i = i + 1usize;
    }
    out_row.result_len = (cursor as! u16) catch {
        return error.DbResultTooLarge;
    };
}

fn db_identifier_bytes(identifier: &SqlIdentifier) !&[byte] {
    if identifier == null || identifier.len as usize > SQL_MAX_IDENTIFIER_LEN {
        return error.DbInvalidExpr;
    }
    return identifier.bytes[0: identifier.len as usize];
}

fn db_literal_text_bytes(literal: &SqlLiteral) !&[byte] {
    if literal == null || literal.text_len as usize > SQL_MAX_LITERAL_LEN {
        return error.DbInvalidExpr;
    }
    return literal.text[0: literal.text_len as usize];
}

fn db_make_select_stmt_from_stmt(src: &SqlStmt, collection_name: &SqlIdentifier, has_where: bool, where_expr: i16, projection_expr: i16, projection_count: u16) SqlStmt {
    var stmt: SqlStmt = src[0];
    stmt.kind = SqlStmtKind.SELECT;
    stmt.select_stmt.collection_name = collection_name[0];
    stmt.select_stmt.item_count = projection_count;
    if projection_count > 0u16 {
        stmt.select_stmt.items[0usize].expr_index = projection_expr;
    }
    stmt.select_stmt.has_where = has_where;
    stmt.select_stmt.where_expr = where_expr;
    stmt.select_stmt.has_order_by = false;
    stmt.select_stmt.order_expr = -1;
    stmt.select_stmt.order_desc = false;
    stmt.select_stmt.has_limit = false;
    stmt.select_stmt.limit_value = 0u32;
    return stmt;
}

fn db_arena_copy_bytes(arena: &Arena, src: &[const byte]) !JsonStrView {
    if arena == null {
        return error.DbInvalidExpr;
    }
    if src.len == 0usize {
        return JsonStrView{
            ptr: null,
            len: 0usize,
        };
    }
    const mem: &byte = arena_alloc(arena, src.len);
    if mem == null {
        return error.DbRowTooLarge;
    }
    _ = mem_copy(mem, src.ptr, src.len);
    return JsonStrView{
        ptr: mem,
        len: src.len,
    };
}

fn db_doc_node_to_json_value(arena: &Arena, node: &[byte]) !JsonValue {
    const tag: DocNodeTag = try doc_node_tag(node);
    if tag == DocNodeTag.NULL {
        return JsonValue.json_null();
    }
    if tag == DocNodeTag.TRUE || tag == DocNodeTag.FALSE {
        return JsonValue.bool_val(try doc_bool_value(node));
    }
    if tag == DocNodeTag.INT64 {
        return JsonValue.int_val(try doc_int64_value(node));
    }
    if tag == DocNodeTag.STRING {
        const text: &[byte] = try doc_string_view(node);
        return JsonValue.str(JsonStrView{
            ptr: text.ptr,
            len: text.len,
        });
    }
    if tag == DocNodeTag.NUMBER_TEXT {
        const text: &[byte] = try doc_number_text_lexeme_view(node);
        return JsonValue.num_text(JsonStrView{
            ptr: text.ptr,
            len: text.len,
        });
    }
    if tag == DocNodeTag.ARRAY {
        const count: u32 = try doc_array_count(node);
        if count == 0u32 {
            return JsonValue.arr(JsonArray{
                items: null,
                len: 0usize,
            });
        }
        const items_mem: &byte = arena_alloc(arena, (count as usize) * DB_JSON_VALUE_ALLOC_SIZE);
        if items_mem == null {
            return error.DbRowTooLarge;
        }
        const items: &JsonValue = items_mem as &JsonValue;
        var i: u32 = 0u32;
        while i < count {
            items[i as usize] = try db_doc_node_to_json_value(arena, try doc_array_index(node, i));
            i = i + 1u32;
        }
        return JsonValue.arr(JsonArray{
            items: items,
            len: count as usize,
        });
    }
    const count: u32 = try doc_object_count(node);
    if count == 0u32 {
        return JsonValue.obj(JsonObject{
            pairs: null,
            len: 0usize,
        });
    }
    const pairs_mem: &byte = arena_alloc(arena, (count as usize) * DB_JSON_KEY_VALUE_ALLOC_SIZE);
    if pairs_mem == null {
        return error.DbRowTooLarge;
    }
    const pairs: &JsonKeyValue = pairs_mem as &JsonKeyValue;
    var i: u32 = 0u32;
    while i < count {
        const key: &[byte] = try doc_object_key_at(node, i);
        pairs[i as usize] = JsonKeyValue{
            key: JsonStrView{
                ptr: key.ptr,
                len: key.len,
            },
            value: try db_doc_node_to_json_value(arena, try doc_object_value_at(node, i)),
        };
        i = i + 1u32;
    }
    return JsonValue.obj(JsonObject{
        pairs: pairs,
        len: count as usize,
    });
}

fn db_exec_value_to_json_value(arena: &Arena, value: &ExecValue) !JsonValue {
    if value == null {
        return error.DbInvalidExpr;
    }
    if value.kind == ExecValueKind.NULL {
        return JsonValue.json_null();
    }
    if value.kind == ExecValueKind.BOOL {
        return JsonValue.bool_val(value.bool_value);
    }
    if value.kind == ExecValueKind.INT64 {
        return JsonValue.int_val(value.i64_value);
    }
    if value.kind == ExecValueKind.UINT64 {
        if value.u64_value <= 9223372036854775807u64 {
            return JsonValue.int_val(value.u64_value as i64);
        }
        var text_buf: [byte: 32] = [];
        const text_len: usize = try exec_encode_u64_text(value.u64_value, text_buf[0: 32]);
        return JsonValue.num_text(try db_arena_copy_bytes(arena, text_buf[0: text_len]));
    }
    if value.kind == ExecValueKind.STRING {
        return JsonValue.str(try db_arena_copy_bytes(arena, value.text[0: value.text_len as usize]));
    }
    if value.kind == ExecValueKind.NUMBER_TEXT {
        return JsonValue.num_text(try db_arena_copy_bytes(arena, value.text[0: value.text_len as usize]));
    }
    return try db_doc_node_to_json_value(arena, value.doc_node);
}

fn db_json_key_equal(key: JsonStrView, field: &[const byte]) bool {
    if key.len != field.len {
        return false;
    }
    var i: usize = 0usize;
    while i < field.len {
        if key.ptr[i] != field.ptr[i] {
            return false;
        }
        i = i + 1usize;
    }
    return true;
}

fn db_json_copy_field_name(arena: &Arena, field: &[const byte]) !JsonStrView {
    return try db_arena_copy_bytes(arena, field);
}

fn db_json_set_path(arena: &Arena, value: &JsonValue, program: &PathProgram, step_index: usize, replacement: &JsonValue) !JsonValue {
    if step_index >= program.step_count as usize {
        return replacement[0];
    }
    if step_index >= @len(program.steps) {
        return error.DbPathError;
    }
    const step: PathStep = program.steps[step_index];
    if step.kind == PathStepKind.FIELD {
        match value[0] {
            .obj(obj) => {
                var found_idx: i32 = 0 - 1;
                var i: usize = 0usize;
                while i < obj.len {
                    if db_json_key_equal(obj.pairs[i].key, step.field[0: step.field_len as usize]) {
                        found_idx = (i as! i32) catch {
                            return error.DbPathError;
                        };
                        break;
                    }
                    i = i + 1usize;
                }
                if found_idx < 0i32 && step_index + 1usize < program.step_count as usize {
                    return error.DbPathError;
                }

                var new_len: usize = obj.len;
                if found_idx < 0i32 {
                    new_len = new_len + 1usize;
                }
                const pairs_mem: &byte = arena_alloc(arena, new_len * DB_JSON_KEY_VALUE_ALLOC_SIZE);
                if pairs_mem == null {
                    return error.DbRowTooLarge;
                }
                const pairs: &JsonKeyValue = pairs_mem as &JsonKeyValue;
                i = 0usize;
                while i < obj.len {
                    pairs[i] = obj.pairs[i];
                    i = i + 1usize;
                }
                if found_idx >= 0i32 {
                    var child: JsonValue = replacement[0];
                    if step_index + 1usize < program.step_count as usize {
                        child = try db_json_set_path(arena, &obj.pairs[found_idx as usize].value, program, step_index + 1usize, replacement);
                    }
                    pairs[found_idx as usize].value = child;
                } else {
                    pairs[obj.len] = JsonKeyValue{
                        key: try db_json_copy_field_name(arena, step.field[0: step.field_len as usize]),
                        value: replacement[0],
                    };
                }
                return JsonValue.obj(JsonObject{
                    pairs: pairs,
                    len: new_len,
                });
            },
            else => {
                return error.DbPathError;
            },
        }
    }

    match value[0] {
        .arr(arr) => {
            if step.index as usize >= arr.len {
                return error.DbPathError;
            }
            if arr.len == 0usize {
                return error.DbPathError;
            }
            const items_mem: &byte = arena_alloc(arena, arr.len * DB_JSON_VALUE_ALLOC_SIZE);
            if items_mem == null {
                return error.DbRowTooLarge;
            }
            const items: &JsonValue = items_mem as &JsonValue;
            var i: usize = 0usize;
            while i < arr.len {
                items[i] = arr.items[i];
                i = i + 1usize;
            }
            if step_index + 1usize >= program.step_count as usize {
                items[step.index as usize] = replacement[0];
            } else {
                items[step.index as usize] = try db_json_set_path(arena, &arr.items[step.index as usize], program, step_index + 1usize, replacement);
            }
            return JsonValue.arr(JsonArray{
                items: items,
                len: arr.len,
            });
        },
        else => {
            return error.DbPathError;
        },
    }
}

fn db_update_row_doc_at_path(row: &DbStoredRow, program: &PathProgram, replacement: &ExecValue) !void {
    var scratch: [byte: DB_TXN_DOC_SCRATCH_MAX] = [];
    var arena: Arena = Arena{ buffer: null, size: 0, used: 0 };
    arena_init(&arena, &scratch[0], DB_TXN_DOC_SCRATCH_MAX);
    const root_json: JsonValue = try db_doc_node_to_json_value(&arena, row.doc_blob[0: row.doc_len as usize]);
    const replacement_json: JsonValue = try db_exec_value_to_json_value(&arena, replacement);
    const updated_json: JsonValue = try db_json_set_path(&arena, &root_json, program, 0usize, &replacement_json);
    var encoded_buf: [byte: DB_DOC_BLOB_MAX] = [];
    const encoded_len: usize = try doc_encode_json_value(&updated_json, encoded_buf[0: DB_DOC_BLOB_MAX]);
    if encoded_len > 0usize {
        _ = mem_copy(&row.doc_blob[0], &encoded_buf[0], encoded_len);
    }
    row.doc_len = (encoded_len as! u16) catch {
        return error.DbRowTooLarge;
    };
}

fn db_txn_stage_update_stmt(txn: &Txn, stmt: &SqlStmt) !void {
    const query_stmt: SqlStmt = db_make_select_stmt_from_stmt(
        stmt,
        &stmt.update_stmt.collection_name,
        stmt.update_stmt.has_where,
        stmt.update_stmt.where_expr,
        stmt.update_stmt.value_expr,
        1u16,
    );
    const bound: BoundSelect = try bind_select_at_stem(db_stem_ptr(txn.db), &query_stmt);
    const plan: QueryPlan = try plan_select(&bound);
    const collection_slot: u16 = try db_find_collection_slot_by_name_in_view(txn.db, txn.view_slot, try db_identifier_bytes(&stmt.update_stmt.collection_name));
    var match_rows: [u16: DB_MAX_CURSOR_ROWS] = [];
    var match_count: u16 = 0u16;
    try db_plan_collect(txn.db, txn.view_slot, &plan, collection_slot, plan.root_node, match_rows[0: DB_MAX_CURSOR_ROWS], &match_count);
    const program: PathProgram = try path_program_compile(sql_path_slice(&stmt.update_stmt.target_path));
    var changed: bool = false;
    var i: u16 = 0u16;
    while i < match_count {
        const row_slot: u16 = match_rows[i as usize];
        const rowref: RowRef = try db_collection_row_ref(txn.db, txn.view_slot, collection_slot, row_slot);
        const new_value: ExecValue = try db_eval_value(txn.db, &bound, &rowref, bound.projection_exprs[0]);
        const state: &CommitViewState = try db_commit_view_state(txn.db, txn.view_slot);
        const collection: &DbCollection = try db_collection_at_in_state(state, collection_slot);
        const row: &DbStoredRow = try db_row_at(collection, row_slot);
        try db_update_row_doc_at_path(row, &program, &new_value);
        changed = true;
        i = i + 1u16;
    }
    if changed {
        txn.has_writes = true;
    }
}

fn db_txn_stage_delete_stmt(txn: &Txn, stmt: &SqlStmt) !void {
    const query_stmt: SqlStmt = db_make_select_stmt_from_stmt(
        stmt,
        &stmt.delete_stmt.collection_name,
        stmt.delete_stmt.has_where,
        stmt.delete_stmt.where_expr,
        -1,
        0u16,
    );
    const bound: BoundSelect = try bind_select_at_stem(db_stem_ptr(txn.db), &query_stmt);
    const plan: QueryPlan = try plan_select(&bound);
    const collection_slot: u16 = try db_find_collection_slot_by_name_in_view(txn.db, txn.view_slot, try db_identifier_bytes(&stmt.delete_stmt.collection_name));
    var match_rows: [u16: DB_MAX_CURSOR_ROWS] = [];
    var match_count: u16 = 0u16;
    try db_plan_collect(txn.db, txn.view_slot, &plan, collection_slot, plan.root_node, match_rows[0: DB_MAX_CURSOR_ROWS], &match_count);
    var changed: bool = false;
    var i: u16 = 0u16;
    while i < match_count {
        const state: &CommitViewState = try db_commit_view_state(txn.db, txn.view_slot);
        const collection: &DbCollection = try db_collection_at_in_state(state, collection_slot);
        const row: &DbStoredRow = try db_row_at(collection, match_rows[i as usize]);
        row.tombstone = true;
        changed = true;
        i = i + 1u16;
    }
    if changed {
        txn.has_writes = true;
    }
}

fn db_txn_stage_create_index_stmt(txn: &Txn, stmt: &SqlStmt) !void {
    if txn == null || txn.db == null {
        return error.DbHandleInvalid;
    }
    const state: &CommitViewState = try db_commit_view_state(txn.db, txn.view_slot);
    const collection_slot: u16 = try db_find_collection_slot_by_name_in_view(txn.db, txn.view_slot, try db_identifier_bytes(&stmt.create_index_stmt.collection_name));
    const collection: &DbCollection = try db_collection_at_in_state(state, collection_slot);
    if collection.secondary_index_count as usize >= DB_MAX_SECONDARY_INDEXES_PER_COLLECTION {
        return error.DbCollectionFull;
    }
    const index_name: &[byte] = try db_identifier_bytes(&stmt.create_index_stmt.index_name);
    const path_bytes: &[const byte] = sql_path_slice(&stmt.create_index_stmt.target_path);
    const program: PathProgram = try path_program_compile(path_bytes);
    var max_index_id: u32 = 0u32;
    var i: u16 = 0u16;
    while i < collection.secondary_index_count {
        const meta: &DbCollectionIndexMeta = &collection.secondary_indexes[i as usize];
        if db_index_name_equal(meta, index_name) || db_index_path_equal(meta, path_bytes) {
            return error.DbIndexExists;
        }
        if meta.index_id > max_index_id {
            max_index_id = meta.index_id;
        }
        i = i + 1u16;
    }
    const slot: usize = collection.secondary_index_count as usize;
    if slot >= DB_MAX_SECONDARY_INDEXES_PER_COLLECTION {
        return error.DbCollectionFull;
    }
    collection.secondary_indexes[slot].present = true;
    collection.secondary_indexes[slot].index_id = max_index_id + 1u32;
    collection.secondary_indexes[slot].root_page = 0u32;
    collection.secondary_indexes[slot].path_segment_count = program.step_count;
    try db_copy_name(index_name, collection.secondary_indexes[slot].name[0: 64], &collection.secondary_indexes[slot].name_len);
    try db_copy_path(path_bytes, collection.secondary_indexes[slot].path[0: 128], &collection.secondary_indexes[slot].path_len);
    collection.secondary_index_count = collection.secondary_index_count + 1u16;
    txn.has_writes = true;
}

fn db_txn_stage_insert(txn: &Txn, collection_name: &[const byte], json_text: &[const byte]) !u64 {
    if txn == null || txn.db == null {
        return error.DbHandleInvalid;
    }
    if !txn.active {
        return error.DbTxnInactive;
    }
    const state: &CommitViewState = try db_commit_view_state(txn.db, txn.view_slot);
    const slot: u16 = try db_find_collection_slot_by_name_in_view(txn.db, txn.view_slot, collection_name);
    const collection_idx: usize = (slot as! usize) catch {
        return error.DbCollectionNotFound;
    };
    if collection_idx >= DB_MAX_COLLECTIONS {
        return error.DbCollectionNotFound;
    }
    if state.collections[collection_idx].next_doc_id == 0u64 ||
        state.collections[collection_idx].next_doc_id == 18446744073709551615u64 {
        return error.DbRowFull;
    }
    const doc_id: u64 = state.collections[collection_idx].next_doc_id;
    var builder: DocBlobBuilder = doc_blob_builder_init();
    try doc_blob_builder_build_json(&builder, json_text);
    var row_slot: usize = DB_MAX_ROWS_PER_COLLECTION;
    var scan_slot: usize = 0usize;
    while scan_slot < state.collections[collection_idx].row_count as usize {
        if state.collections[collection_idx].rows[scan_slot].present &&
            state.collections[collection_idx].rows[scan_slot].tombstone {
            row_slot = scan_slot;
            break;
        }
        scan_slot = scan_slot + 1usize;
    }
    if row_slot >= DB_MAX_ROWS_PER_COLLECTION {
        row_slot = state.collections[collection_idx].row_count as usize;
    }
    if row_slot >= DB_MAX_ROWS_PER_COLLECTION {
        return error.DbRowFull;
    }
    const row: &DbStoredRow = &state.collections[collection_idx].rows[row_slot];
    row.present = true;
    row.tombstone = false;
    row.doc_id = doc_id;
    row.doc_len = builder.doc_len;
    if builder.doc_len > 0u16 {
        _ = mem_copy(&row.doc_blob[0], &builder.doc_blob[0], builder.doc_len as usize);
    }
    if state.collections[collection_idx].primary_root_page == 0u32 {
        state.collections[collection_idx].primary_root_page = 2u32 + state.collections[collection_idx].collection_id;
    }
    state.collections[collection_idx].next_doc_id = state.collections[collection_idx].next_doc_id + 1u64;
    row.record_ptr = record_pointer_make(db_collection_data_page_id(&state.collections[collection_idx]), row_slot as u16);
    if row_slot == state.collections[collection_idx].row_count as usize {
        state.collections[collection_idx].row_count = state.collections[collection_idx].row_count + 1u16;
    }
    txn.has_writes = true;
    return doc_id;
}

fn db_txn_stage_insert_stmt(txn: &Txn, stmt: &SqlInsertStmt) !u64 {
    return try db_txn_stage_insert(txn, try db_identifier_bytes(&stmt.collection_name), try db_literal_text_bytes(&stmt.json_text));
}

fn db_txn_commit_persist(txn: &Txn) !WalCommit {
    if txn == null || txn.db == null {
        return error.DbHandleInvalid;
    }
    const state: &CommitViewState = try db_commit_view_state(txn.db, txn.view_slot);
    const current: &CommitViewState = try db_current_view_state(txn.db);
    const info: PagerOpenInfo = try pager_open_at_stem(db_stem_ptr(txn.db));
    const next_lsn: u64 = info.meta.commit_lsn + 1u64;
    var max_page_count: u32 = info.meta.page_count;
    var catalog_raw: [byte: 8192] = [];
    const catalog_page: &[byte] = catalog_raw[0: info.meta.page_size as usize];
    try pager_read_page_at_stem(db_stem_ptr(txn.db), info.meta.catalog_root, catalog_page);
    var batch: WalBatch = wal_batch_init(next_lsn, next_lsn);
    try wal_batch_append_begin(&batch);
    var collection_idx: u16 = 0u16;
    while collection_idx < state.collection_count {
        const collection: &DbCollection = &state.collections[collection_idx as usize];
        const current_collection: &DbCollection = &current.collections[collection_idx as usize];
        if collection.present {
            var current_index_count: u16 = current_collection.secondary_index_count;
            while current_index_count < collection.secondary_index_count {
                const index_idx: usize = (current_index_count as! usize) catch {
                    return error.DbCollectionFull;
                };
                if index_idx >= DB_MAX_SECONDARY_INDEXES_PER_COLLECTION {
                    return error.DbCollectionFull;
                }
                const index_meta: &DbCollectionIndexMeta = &collection.secondary_indexes[index_idx];
                _ = try catalog_page_append_index(
                    catalog_page,
                    collection.name[0: collection.name_len as usize],
                    index_meta.name[0: index_meta.name_len as usize],
                    index_meta.path[0: index_meta.path_len as usize],
                    index_meta.path_segment_count,
                );
                current_index_count = current_index_count + 1u16;
            }
            var current_next_doc_id: u64 = current_collection.next_doc_id;
            while current_next_doc_id < collection.next_doc_id {
                _ = try catalog_page_allocate_next_doc_id(catalog_page, collection.name[0: collection.name_len as usize]);
                current_next_doc_id = current_next_doc_id + 1u64;
            }
            const page_id: u32 = db_collection_data_page_id(collection);
            if page_id >= 2u32 {
                if page_id + 1u32 > max_page_count {
                    max_page_count = page_id + 1u32;
                }
                var row_idx: u16 = 0u16;
                while row_idx < collection.row_count {
                    const row: &DbStoredRow = &collection.rows[row_idx as usize];
                    if row.present {
                        row.record_ptr = record_pointer_make(page_id, row_idx);
                    }
                    row_idx = row_idx + 1u16;
                }
                var raw_page: [byte: 8192] = [];
                const page_buf: &[byte] = raw_page[0: info.meta.page_size as usize];
                try db_collection_encode_page(collection, info.meta.page_size, txn.db.now_ms, page_buf);
                const header: &PageHeader = page_header_from_buf(page_buf);
                if header == null {
                    return error.DbCollectionPageMissing;
                }
                header.page_lsn = next_lsn;
                _ = try page_checksum_finalize(page_buf);
                try wal_batch_append_page(&batch, page_id, next_lsn, page_buf);
            }
        }
        collection_idx = collection_idx + 1u16;
    }
    const catalog_header: &PageHeader = page_header_from_buf(catalog_page);
    if catalog_header == null {
        return error.DbCollectionPageMissing;
    }
    catalog_header.page_lsn = next_lsn;
    _ = try page_checksum_finalize(catalog_page);
    try wal_batch_append_page(&batch, info.meta.catalog_root, next_lsn, catalog_page);
    const commit: WalCommit = WalCommit{
        txn_id: next_lsn,
        commit_lsn: next_lsn,
        catalog_root: info.meta.catalog_root,
        page_count: max_page_count,
        freelist_head: info.meta.freelist_head,
    };
    try wal_batch_append_commit(&batch, &commit);
    _ = try pager_commit_batch_at_stem(db_stem_ptr(txn.db), &batch, null);
    return commit;
}

fn db_plan_collect(db: &DbHandle, view_slot: u16, plan: &QueryPlan, collection_slot: u16, node_index: i16, out_rows: &[u16], count_out: &u16) !void {
    const node: &PlanNode = try plan_node(plan, node_index);
    const state: &CommitViewState = try db_commit_view_state(db, view_slot);
    const collection_idx: usize = (collection_slot as! usize) catch {
        return error.DbCollectionNotFound;
    };
    if collection_idx >= DB_MAX_COLLECTIONS {
        return error.DbCollectionNotFound;
    }
    const collection: &DbCollection = &state.collections[collection_idx];
    if node.kind == PlanNodeKind.SEQ_SCAN {
        var out_count: u16 = 0u16;
        var i: u16 = 0u16;
        while i < collection.row_count {
            const row: &DbStoredRow = &collection.rows[i as usize];
            if row.present && !row.tombstone {
                if out_count as usize >= out_rows.len {
                    return error.DbRowFull;
                }
                out_rows.ptr[out_count as usize] = i;
                out_count = out_count + 1u16;
            }
            i = i + 1u16;
        }
        count_out[0] = out_count;
        return;
    }
    if node.kind == PlanNodeKind.PRIMARY_LOOKUP {
        const ptr: RecordPointer = primary_btree_lookup(&db.primary_indexes[collection_idx], node.lookup_doc_id) catch {
            count_out[0] = 0u16;
            return;
        };
        var i: u16 = 0u16;
        while i < collection.row_count {
            const row: &DbStoredRow = &collection.rows[i as usize];
            if row.present && !row.tombstone && row.record_ptr.page_id == ptr.page_id && row.record_ptr.slot_id == ptr.slot_id {
                out_rows.ptr[0usize] = i;
                count_out[0] = 1u16;
                return;
            }
            i = i + 1u16;
        }
        count_out[0] = 0u16;
        return;
    }
    if node.kind == PlanNodeKind.INDEX_SCAN {
        const index_state: &DbSecondaryIndexState = try db_secondary_index_state(db, collection_slot, node.index_slot);
        if !index_state.present {
            count_out[0] = 0u16;
            return;
        }
        var out_count: u16 = 0u16;
        var i: u16 = 0u16;
        while i < index_state.row_count {
            const row_slot: u16 = index_state.row_slots[i as usize];
            const rowref: RowRef = try db_collection_row_ref(db, view_slot, collection_slot, row_slot);
            if try db_eval_predicate(db, &plan.bound, &rowref, node.filter_expr) {
                if out_count as usize >= out_rows.len {
                    return error.DbRowFull;
                }
                out_rows.ptr[out_count as usize] = row_slot;
                out_count = out_count + 1u16;
            }
            i = i + 1u16;
        }
        count_out[0] = out_count;
        return;
    }
    var child_rows: [u16: DB_MAX_CURSOR_ROWS] = [];
    var child_count: u16 = 0u16;
    try db_plan_collect(db, view_slot, plan, collection_slot, node.child, child_rows[0: DB_MAX_CURSOR_ROWS], &child_count);
    if node.kind == PlanNodeKind.LIMIT {
        var limited: u16 = child_count;
        const limit_u16: u16 = (node.limit_value as! u16) catch {
            return error.DbRowFull;
        };
        if limited > limit_u16 {
            limited = limit_u16;
        }
        var i: u16 = 0u16;
        while i < limited {
            out_rows.ptr[i as usize] = child_rows[i as usize];
            i = i + 1u16;
        }
        count_out[0] = limited;
        return;
    }
    if node.kind == PlanNodeKind.SORT {
        var i: u16 = 0u16;
        while i < child_count {
            out_rows.ptr[i as usize] = child_rows[i as usize];
            i = i + 1u16;
        }
        i = 1u16;
        while i < child_count {
            const current: u16 = out_rows.ptr[i as usize];
            var j: usize = i as usize;
            while j > 0usize {
                const prev: u16 = out_rows.ptr[j - 1usize];
                const cmp: i32 = try db_compare_rows_for_sort(db, &plan.bound, view_slot, collection_slot, prev, current, node.order_expr, node.order_desc);
                if cmp <= 0 {
                    break;
                }
                out_rows.ptr[j] = prev;
                j = j - 1usize;
            }
            out_rows.ptr[j] = current;
            i = i + 1u16;
        }
        count_out[0] = child_count;
        return;
    }
    if node.kind == PlanNodeKind.FILTER {
        var out_count: u16 = 0u16;
        var i: u16 = 0u16;
        while i < child_count {
            const rowref: RowRef = try db_collection_row_ref(db, view_slot, collection_slot, child_rows[i as usize]);
            if try db_eval_predicate(db, &plan.bound, &rowref, node.filter_expr) {
                out_rows.ptr[out_count as usize] = child_rows[i as usize];
                out_count = out_count + 1u16;
            }
            i = i + 1u16;
        }
        count_out[0] = out_count;
        return;
    }
    return error.DbInvalidProjection;
}

export fn db_test_init_at_stem(db: &DbHandle, stem: &const byte) !void {
    if db == null || stem == null {
        return error.DbHandleInvalid;
    }
    db.stem_len = 0u16;
    db.snapshot_policy = db_default_snapshot_policy();
    db.snapshot_status = SnapshotPressureStatus{
        retired_bytes: 0u64,
        retired_views: 0u32,
    };
    db.snapshot_status_override_enabled = false;
    db.snapshot_status_override = SnapshotPressureStatus{
        retired_bytes: 0u64,
        retired_views: 0u32,
    };
    db.now_ms = 0u64;
    db.current_view_slot = 0u16;
    db.next_view_generation = 2u64;
    db.next_page_table_gen = 2u64;
    db.cursor_release_counter = null;
    db.pin_release_counter = null;
    var index_slot: usize = 0usize;
    while index_slot < DB_MAX_COLLECTIONS {
        db.primary_indexes[index_slot] = try primary_btree_init(256u32);
        index_slot = index_slot + 1usize;
    }
    index_slot = 0usize;
    while index_slot < DB_MAX_COLLECTIONS * DB_MAX_SECONDARY_INDEXES_PER_COLLECTION {
        db_secondary_index_state_reset(&db.secondary_indexes[index_slot]);
        index_slot = index_slot + 1usize;
    }
    var i: usize = 0usize;
    while i < DB_MAX_COMMIT_VIEWS {
        db_clear_commit_view_state(&db.commit_views[i]);
        i = i + 1usize;
    }
    const initial: &CommitViewState = &db.commit_views[0usize];
    initial.present = true;
    initial.retired = false;
    initial.reader_pins = 0u32;
    initial.view = CommitView{
        generation: 1u64,
        commit_lsn: 0u64,
        catalog_root: 2u32,
        page_count: 3u32,
        freelist_head: 0u32,
        page_table_gen: 1u64,
    };
    initial.collection_count = 0u16;
    db_finalize_view_state(initial);
    db_refresh_snapshot_status(db);
    const len: usize = strlen(stem);
    if len + 1usize > DB_PATH_BUF_SIZE {
        return error.DbHandleInvalid;
    }
    db.stem_len = (len as! u16) catch {
        return error.DbHandleInvalid;
    };
    _ = mem_copy(&db.stem[0], stem, len);
    db.stem[len] = 0 as byte;
}

export fn db_test_create_at_stem(db: &DbHandle, stem: &const byte) !void {
    try catalog_cleanup_stem(stem);
    try catalog_create_db_at_stem(stem, NOSQLITE_PAGE_SIZE_DEFAULT);
    try db_test_open_at_stem(db, stem);
}

export fn db_test_open_at_stem(db: &DbHandle, stem: &const byte) !void {
    try db_test_init_at_stem(db, stem);
    try db_reload_from_disk(db);
}

export fn db_check_at_stem(stem: &const byte) !DbCheckReport {
    const wal_report: WalCheckReport = try pager_check_wal_at_stem(stem);
    const info: PagerOpenInfo = try pager_open_at_stem(stem);
    if !db_check_meta_state_valid(&info.meta) {
        return error.DbPageCorrupt;
    }

    const snapshot: CatalogSnapshot = try catalog_load_at_stem(stem);
    const view: CatalogView = try catalog_view_from_page(snapshot.page[0: snapshot.page_size as usize]);
    var report: DbCheckReport = DbCheckReport{
        page_count: info.meta.page_count,
        checked_pages: 3u32,
        collection_count: view.root.collection_count,
        row_count: 0u32,
        wal_bytes: wal_report.wal_bytes,
        wal_records: wal_report.record_count,
        committed_wal_txns: wal_report.committed_txns,
    };

    var collection_idx: u32 = 0u32;
    while collection_idx < view.root.collection_count {
        const entry: CatalogCollectionView = try catalog_collection_at(&view, collection_idx);
        try db_check_collection_at_stem(stem, info.meta.page_size, &entry, &report.row_count);
        report.checked_pages = report.checked_pages + 1u32;
        collection_idx = collection_idx + 1u32;
    }
    return report;
}

export fn db_check(db: &DbHandle) !DbCheckReport {
    if db == null {
        return error.DbHandleInvalid;
    }
    return try db_check_at_stem(db_stem_ptr(db));
}

export fn db_test_track_drops(db: &DbHandle, cursor_counter: &i32, pin_counter: &i32) void {
    if db == null {
        return;
    }
    db.cursor_release_counter = cursor_counter;
    db.pin_release_counter = pin_counter;
}

export fn db_test_set_now_ms(db: &DbHandle, now_ms: u64) void {
    if db != null {
        db.now_ms = now_ms;
    }
}

export fn db_test_set_snapshot_policy(db: &DbHandle, policy: SnapshotPressurePolicy) void {
    if db != null {
        db.snapshot_policy = policy;
    }
}

export fn db_test_set_snapshot_status(db: &DbHandle, status: SnapshotPressureStatus) void {
    if db != null {
        db.snapshot_status_override_enabled = true;
        db.snapshot_status_override = status;
    }
}

export fn db_test_clear_snapshot_status_override(db: &DbHandle) void {
    if db != null {
        db.snapshot_status_override_enabled = false;
        db_refresh_snapshot_status(db);
    }
}

export fn db_test_snapshot_status(db: &DbHandle) SnapshotPressureStatus {
    return db_effective_snapshot_status(db);
}

export fn db_test_current_commit_view(db: &DbHandle) CommitView {
    const state: &CommitViewState = db_current_view_state(db) catch {
        return db_zero_commit_view();
    };
    return state.view;
}

export fn db_test_reset_primary_index(db: &DbHandle, collection_name: &[const byte]) !void {
    if db == null {
        return error.DbHandleInvalid;
    }
    const slot: u16 = try db_find_collection_slot_by_name(db, collection_name);
    db.primary_indexes[slot as usize] = try primary_btree_init(256u32);
}

export fn db_test_create_collection(db: &DbHandle, name: &[const byte]) !void {
    if db == null {
        return error.DbCollectionFull;
    }
    const current: &CommitViewState = try db_current_view_state(db);
    if current.collection_count as usize >= DB_MAX_COLLECTIONS {
        return error.DbCollectionFull;
    }
    const created: CollectionMeta = try catalog_create_collection_at_stem(db_stem_ptr(db), name);
    const info: PagerOpenInfo = try pager_open_at_stem(db_stem_ptr(db));
    const view_slot: u16 = try db_stage_view_from_current(db);
    const state: &CommitViewState = try db_commit_view_state(db, view_slot);
    errdefer {
        db_clear_commit_view_state(state);
        db_refresh_snapshot_status(db);
    }
    const slot: usize = state.collection_count as usize;
    if slot >= DB_MAX_COLLECTIONS {
        return error.DbCollectionFull;
    }
    db_collection_reset(&state.collections[slot]);
    state.collections[slot].present = true;
    state.collections[slot].collection_id = created.collection_id;
    state.collections[slot].next_doc_id = created.next_doc_id;
    state.collections[slot].primary_root_page = created.primary_root_page;
    try db_copy_name(name, state.collections[slot].name[0: 64], &state.collections[slot].name_len);
    db.primary_indexes[slot] = try primary_btree_init(256u32);
    state.collection_count = state.collection_count + 1u16;
    state.view.commit_lsn = info.meta.commit_lsn;
    state.view.page_count = info.meta.page_count;
    state.view.catalog_root = info.meta.catalog_root;
    state.view.freelist_head = info.meta.freelist_head;
    try db_publish_view_slot(db, view_slot);
}

export fn db_test_insert_json(db: &DbHandle, collection_name: &[const byte], json: &[const byte]) !u64 {
    if db == null || json.ptr == null {
        return error.DbHandleInvalid;
    }
    var txn: Txn = try txn_begin(db);
    errdefer {
        _ = txn_rollback(&txn) catch {};
    }
    const doc_id: u64 = try db_txn_stage_insert(&txn, collection_name, json);
    try txn_commit(&txn);
    return doc_id;
}

export fn txn_begin(db: &DbHandle) !Txn {
    if db == null {
        return error.DbHandleInvalid;
    }
    const view_slot: u16 = try db_stage_view_from_current(db);
    return Txn{
        db: db,
        writer_guard: writer_lock_guard_acquire(db.next_view_generation, db.next_view_generation),
        view_slot: view_slot,
        has_writes: false,
        active: true,
        committed: false,
    };
}

export fn txn_exec(txn: &Txn, sql: &[const byte]) !void {
    if txn == null || txn.db == null {
        return error.DbHandleInvalid;
    }
    if !txn.active {
        return error.DbTxnInactive;
    }
    const stmt: SqlStmt = try sql_parse(sql);
    if stmt.kind == SqlStmtKind.INSERT {
        _ = try db_txn_stage_insert_stmt(txn, &stmt.insert_stmt);
        return;
    }
    if stmt.kind == SqlStmtKind.UPDATE {
        try db_txn_stage_update_stmt(txn, &stmt);
        return;
    }
    if stmt.kind == SqlStmtKind.DELETE {
        try db_txn_stage_delete_stmt(txn, &stmt);
        return;
    }
    if stmt.kind == SqlStmtKind.CREATE_INDEX {
        try db_txn_stage_create_index_stmt(txn, &stmt);
        return;
    }
    return error.DbUnsupportedStmt;
}

export fn txn_commit(txn: &Txn) !void {
    if txn == null || txn.db == null {
        return error.DbHandleInvalid;
    }
    if !txn.active {
        return error.DbTxnInactive;
    }
    if !txn.has_writes {
        writer_lock_guard_release(&txn.writer_guard);
        txn.committed = true;
        txn.active = false;
        return;
    }
    const committed: WalCommit = try db_txn_commit_persist(txn);
    errdefer {
        _ = db_reload_from_disk(txn.db) catch {};
        writer_lock_guard_release(&txn.writer_guard);
        txn.active = false;
    }
    const staged: &CommitViewState = try db_commit_view_state(txn.db, txn.view_slot);
    staged.view.commit_lsn = committed.commit_lsn;
    staged.view.page_count = committed.page_count;
    staged.view.catalog_root = committed.catalog_root;
    staged.view.freelist_head = committed.freelist_head;
    const collection_count: u16 = staged.collection_count;
    try db_publish_view_slot(txn.db, txn.view_slot);
    var i: u16 = 0u16;
    while i < collection_count {
        try db_rebuild_primary_index(txn.db, i);
        try db_rebuild_secondary_indexes(txn.db, i);
        i = i + 1u16;
    }
    writer_lock_guard_release(&txn.writer_guard);
    txn.committed = true;
    txn.active = false;
}

export fn txn_rollback(txn: &Txn) !void {
    if txn == null || txn.db == null {
        return error.DbHandleInvalid;
    }
    if !txn.active {
        return error.DbTxnInactive;
    }
    const staged: &CommitViewState = try db_commit_view_state(txn.db, txn.view_slot);
    db_clear_commit_view_state(staged);
    db_refresh_snapshot_status(txn.db);
    writer_lock_guard_release(&txn.writer_guard);
    txn.active = false;
}

export fn db_exec(db: &DbHandle, sql: &[const byte]) !void {
    if db == null {
        return error.DbHandleInvalid;
    }
    const stmt: SqlStmt = try sql_parse(sql);
    if stmt.kind == SqlStmtKind.CREATE_COLLECTION {
        try db_test_create_collection(db, try db_identifier_bytes(&stmt.create_collection.collection_name));
        return;
    }
    if stmt.kind == SqlStmtKind.INSERT ||
        stmt.kind == SqlStmtKind.UPDATE ||
        stmt.kind == SqlStmtKind.DELETE ||
        stmt.kind == SqlStmtKind.CREATE_INDEX {
        var txn: Txn = try txn_begin(db);
        errdefer {
            _ = txn_rollback(&txn) catch {};
        }
        if stmt.kind == SqlStmtKind.INSERT {
            _ = try db_txn_stage_insert_stmt(&txn, &stmt.insert_stmt);
        } else if stmt.kind == SqlStmtKind.UPDATE {
            try db_txn_stage_update_stmt(&txn, &stmt);
        } else if stmt.kind == SqlStmtKind.DELETE {
            try db_txn_stage_delete_stmt(&txn, &stmt);
        } else {
            try db_txn_stage_create_index_stmt(&txn, &stmt);
        }
        try txn_commit(&txn);
        return;
    }
    return error.DbUnsupportedStmt;
}

export fn db_query_cursor(db: &DbHandle, sql: &[const byte]) !QueryCursor {
    if db == null {
        return error.DbHandleInvalid;
    }
    db_cleanup_retired_views(db);
    const effective_status: SnapshotPressureStatus = db_effective_snapshot_status(db);
    if !snapshot_pressure_cursor_can_open(&db.snapshot_policy, &effective_status) {
        return error.SnapshotPressure;
    }
    const stmt: SqlStmt = try sql_parse(sql);
    if stmt.kind != SqlStmtKind.SELECT {
        return error.DbUnsupportedStmt;
    }
    const bound: BoundSelect = try bind_select_at_stem(db_stem_ptr(db), &stmt);
    const plan: QueryPlan = try plan_select(&bound);
    const view_slot: u16 = try db_pin_current_view_slot(db);
    errdefer {
        db_unpin_view_slot(db, view_slot);
    }
    const view_state: &CommitViewState = try db_commit_view_state(db, view_slot);
    const collection_slot: u16 = try db_find_collection_slot_by_id_in_view(db, view_slot, bound.collection_id);
    var match_rows: [u16: DB_MAX_CURSOR_ROWS] = [];
    var match_count: u16 = 0u16;
    try db_plan_collect(db, view_slot, &plan, collection_slot, plan.root_node, match_rows[0: DB_MAX_CURSOR_ROWS], &match_count);
    return QueryCursor{
        db: db,
        pin: CommitViewPin{
            db: db,
            view_slot: view_slot,
            view: view_state.view,
            lease: cursor_lease_start(&db.snapshot_policy, db.now_ms),
            held: true,
            release_counter: db.pin_release_counter,
        },
        plan: plan,
        collection_slot: collection_slot,
        match_count: match_count,
        match_rows: match_rows,
        next_index: 0u16,
        has_current: false,
        current_row: RowRef{
            doc_id: 0u64,
            record_ptr: record_pointer_make(0u32, 0u16),
            doc_blob: &""[0: 0],
        },
        release_counter: db.cursor_release_counter,
    };
}

export fn cursor_next(cursor: &QueryCursor) !bool {
    if cursor == null || cursor.db == null {
        return error.DbHandleInvalid;
    }
    try cursor_lease_validate(&cursor.pin.lease, cursor.db.now_ms);
    if cursor.next_index >= cursor.match_count {
        cursor.has_current = false;
        return false;
    }
    const next_idx: usize = (cursor.next_index as! usize) catch {
        return error.DbInvalidProjection;
    };
    if next_idx >= DB_MAX_CURSOR_ROWS {
        return error.DbInvalidProjection;
    }
    const row_slot: u16 = cursor.match_rows[next_idx];
    cursor.current_row = try db_collection_row_ref(cursor.db, cursor.pin.view_slot, cursor.collection_slot, row_slot);
    cursor.next_index = cursor.next_index + 1u16;
    cursor.has_current = true;
    return true;
}

export fn cursor_row(cursor: &QueryCursor) !RowRef {
    if cursor == null || !cursor.has_current {
        return error.DbInvalidProjection;
    }
    return cursor.current_row;
}

export fn db_query_with_allocator(db: &DbHandle, sql: &[const byte], allocator: IAllocator) !QueryResult {
    const stmt: SqlStmt = try sql_parse(sql);
    if stmt.kind == SqlStmtKind.EXPLAIN {
        var select_stmt: SqlStmt = stmt;
        select_stmt.kind = SqlStmtKind.SELECT;
        const bound: BoundSelect = try bind_select_at_stem(db_stem_ptr(db), &select_stmt);
        const plan: QueryPlan = try plan_select(&bound);
        var explain_buf: [byte: 1024] = [];
        const explain_len: usize = try plan_explain(&plan, explain_buf[0: 1024]);
        return try db_build_single_text_result_with_allocator(explain_buf[0: explain_len], allocator);
    }
    var cursor: QueryCursor = try db_query_cursor(db, sql);
    const storage_size: usize = QUERY_RESULT_MAX_ROWS * (@size_of(OwnedRow) as usize);
    const rows_alloc: !&byte = allocator.alloc(storage_size);
    if rows_alloc.error_id != 0u32 {
        return error.DbResultTooLarge;
    }
    const rows_mem: &byte = rows_alloc.value;
    errdefer {
        allocator.dealloc(rows_mem);
    }
    _ = mem_set(rows_mem, 0 as byte, storage_size);
    const rows_ptr: &OwnedRow = rows_mem as &OwnedRow;
    var query_result: QueryResult = QueryResult{
        allocator: allocator,
        column_count: cursor.plan.bound.projection_count,
        row_count: 0u32,
        rows: rows_ptr,
    };
    while try cursor_next(&cursor) {
        if query_result.row_count as usize >= QUERY_RESULT_MAX_ROWS {
            return error.DbResultTooLarge;
        }
        const rowref: RowRef = try cursor_row(&cursor);
        const row_idx: usize = (query_result.row_count as! usize) catch {
            return error.DbResultTooLarge;
        };
        if row_idx >= QUERY_RESULT_MAX_ROWS {
            return error.DbResultTooLarge;
        }
        const row_addr: usize = @usize_from_ptr(query_result.rows as &void) + row_idx * (@size_of(OwnedRow) as usize);
        const out_row: &OwnedRow = @ptr_from_usize(row_addr) as &OwnedRow;
        try db_project_row(&cursor.plan.bound, &rowref, out_row);
        query_result.row_count = query_result.row_count + 1u32;
    }
    const out_rows: &OwnedRow = query_result.rows;
    const out_row_count: u32 = query_result.row_count;
    const out_column_count: u16 = query_result.column_count;
    query_result.rows = null;
    return QueryResult{
        allocator: query_result.allocator,
        column_count: out_column_count,
        row_count: out_row_count,
        rows: out_rows,
    };
}

export fn db_query(db: &DbHandle, sql: &[const byte]) !QueryResult {
    const allocator: IAllocator = get_allocator()[0];
    return try db_query_with_allocator(db, sql, allocator);
}
